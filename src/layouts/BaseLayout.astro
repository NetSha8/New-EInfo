---
export interface Props {
    title?: string;
    description?: string;
    ogImage?: string;
    ogType?: string;
    canonicalUrl?: string;
    articleDate?: string;
    articleModified?: string;
    noindex?: boolean;
    jsonLd?: Record<string, unknown>;
}

const {
    title = "E Informatique | Dépannage informatique à Rivesaltes et dans les Pyrénées-Orientales",
    description = "Dépannage informatique, création de site web, sécurité et VPS pour TPE/PME. Intervention à Rivesaltes, Perpignan et dans les Pyrénées-Orientales, à distance partout en France.",
    ogImage = "/images/og-default.png",
    ogType = "website",
    canonicalUrl,
    articleDate,
    articleModified,
    noindex = false,
    jsonLd,
} = Astro.props;

const siteUrl = "https://einformatique.fr";
const siteName = "E Informatique";
const currentUrl = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = ogImage.startsWith("http") ? ogImage : new URL(ogImage, siteUrl).href;

import "../styles/global.css";
---

<!doctype html>
<html lang="fr">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"} />

        <!-- Primary Meta Tags -->
        <title>{title}</title>
        <meta name="title" content={title} />
        <meta name="description" content={description} />
        <meta name="author" content="Elian — E Informatique" />
        <meta
            name="keywords"
            content="dépannage informatique Rivesaltes, technicien informatique Rivesaltes, dépannage informatique Perpignan, informatique Pyrénées-Orientales, création site web Perpignan, sécurité informatique PME, hébergement VPS"
        />
        <meta name="geo.region" content="FR-66" />
        <meta name="geo.placename" content="Rivesaltes" />
        <meta name="geo.position" content="42.7705;2.8732" />
        <meta name="ICBM" content="42.7705, 2.8732" />

        <!-- Canonical URL -->
        <link rel="canonical" href={currentUrl} />

        <!-- Favicon -->
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

        <!-- RSS Feed -->
        <link rel="alternate" type="application/rss+xml" title="Blog E Informatique" href={`${siteUrl}/rss.xml`} />

        <!-- AI / LLMs discoverability -->
        <link rel="alternate" type="text/plain" href={`${siteUrl}/llms.txt`} title="LLM-friendly site summary" />

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content={ogType} />
        <meta property="og:url" content={currentUrl} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImageUrl} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:site_name" content={siteName} />
        <meta property="og:locale" content="fr_FR" />
        {articleDate && <meta property="article:published_time" content={articleDate} />}
        {articleModified && <meta property="article:modified_time" content={articleModified} />}

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:url" content={currentUrl} />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImageUrl} />

        <!-- Preload Critical Fonts -->
        <link
            rel="preload"
            href="/fonts/satoshi/Satoshi-Regular.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link
            rel="preload"
            href="/fonts/satoshi/Satoshi-Bold.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />

        <!-- Schema.org LocalBusiness (default) -->
        <script
            type="application/ld+json"
            set:html={JSON.stringify({
                "@context": "https://schema.org",
                "@type": "LocalBusiness",
                "@id": `${siteUrl}/#business`,
                name: siteName,
                description: description,
                url: siteUrl,
                telephone: "07 68 53 51 50",
                email: "elianb.pro@gmail.com",
                founder: {
                    "@type": "Person",
                    name: "Elian",
                    jobTitle: "Technicien informatique indépendant",
                },
                address: {
                    "@type": "PostalAddress",
                    addressLocality: "Rivesaltes",
                    addressRegion: "Occitanie",
                    postalCode: "66600",
                    addressCountry: "FR",
                },
                geo: {
                    "@type": "GeoCoordinates",
                    latitude: "42.7705",
                    longitude: "2.8732",
                },
                areaServed: [
                    {
                        "@type": "City",
                        name: "Rivesaltes",
                    },
                    {
                        "@type": "AdministrativeArea",
                        name: "Pyrénées-Orientales",
                    },
                    {
                        "@type": "Country",
                        name: "France",
                    },
                ],
                serviceType: [
                    "Dépannage informatique",
                    "Création de sites web",
                    "Sécurité informatique",
                    "Hébergement VPS Linux",
                    "Assistance informatique TPE/PME",
                ],
                knowsAbout: [
                    "Windows", "macOS", "Linux", "Réseaux", "WordPress",
                    "Astro", "Docker", "Nginx", "Cybersécurité", "VPS",
                ],
                priceRange: "$$",
                sameAs: [],
            })}
        />

        <!-- Schema.org WebSite (for sitelinks search) -->
        <script
            type="application/ld+json"
            set:html={JSON.stringify({
                "@context": "https://schema.org",
                "@type": "WebSite",
                "@id": `${siteUrl}/#website`,
                name: siteName,
                url: siteUrl,
                description: "Technicien informatique indépendant à Rivesaltes. Dépannage, création de site web, sécurité et VPS pour les TPE/PME.",
                inLanguage: "fr-FR",
                publisher: {
                    "@id": `${siteUrl}/#business`,
                },
            })}
        />

        <!-- Custom JSON-LD (page-specific) -->
        {jsonLd && (
            <script
                type="application/ld+json"
                set:html={JSON.stringify(jsonLd)}
            />
        )}
    </head>
    <body class="min-h-screen antialiased">
        <slot />

        <script>
            // Simple Intersection Observer for scroll animations
            const observerOptions = {
                root: null,
                rootMargin: "0px",
                threshold: 0.01,
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add("active");
                        observer.unobserve(entry.target);
                    }
                });
            }, observerOptions);

            const initObserver = () => {
                const hiddenElements = document.querySelectorAll(".reveal");
                hiddenElements.forEach((el) => {
                    observer.observe(el);
                });
            };

            // Handle both cases: script loads before or after DOMContentLoaded
            if (document.readyState === "loading") {
                document.addEventListener("DOMContentLoaded", initObserver);
            } else {
                initObserver();
            }

            setTimeout(() => {
                document.querySelectorAll(".reveal:not(.active)").forEach((el) => el.classList.add("active"));
            }, 100);
        </script>
    </body>
</html>

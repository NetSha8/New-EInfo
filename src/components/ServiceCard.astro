---
import { Check } from "lucide-astro";

export interface Props {
    icon: string;
    title: string;
    items: string[];
    highlight?: string;
    className?: string;
}

const { icon, title, items, highlight, className = "" } = Astro.props;

// Map icon names to Lucide components
import {
    Globe,
    ShoppingBag,
    Settings,
    Bot,
    Rocket,
    Wrench,
    Zap,
    Lock,
    Shield,
} from "lucide-astro";

const iconMap: Record<string, any> = {
    globe: Globe,
    "shopping-bag": ShoppingBag,
    settings: Settings,
    bot: Bot,
    rocket: Rocket,
    wrench: Wrench,
    zap: Zap,
    lock: Lock,
    shield: Shield,
};

const IconComponent = iconMap[icon] || Globe;
---

<article class={`glass-card glass-card--static reveal p-6 md:p-8 h-full group ${className}`}>
    <!-- Icon -->
    <div
        class="icon-wrap w-12 h-12 rounded-xl bg-primary-600/10 flex items-center justify-center mb-4 relative"
    >
        <IconComponent class="w-6 h-6 text-primary-400 relative z-10" />
    </div>

    <!-- Title -->
    <h3 class="text-xl md:text-2xl font-bold text-main mb-4">{title}</h3>

    <!-- Highlight (optional) -->
    {highlight && <p class="text-secondary mb-4 text-sm">{highlight}</p>}

    <!-- Items List -->
    <ul class="space-y-2">
        {
            items.map((item) => (
                <li class="flex items-start gap-2 text-secondary">
                    <Check class="w-5 h-5 text-primary-400 flex-shrink-0 mt-0.5" />
                    <span>{item}</span>
                </li>
            ))
        }
    </ul>
</article>

<style>
  /*
   * Icon draw-in: animate SVG strokes in .icon-wrap when card enters viewport.
   * Targets only the primary icon (not the Check icons in the list).
   * stroke-dasharray 200 covers all Lucide path lengths at 24×24px.
   */
  @media (prefers-reduced-motion: no-preference) {
    .icon-wrap :global(svg path),
    .icon-wrap :global(svg polyline),
    .icon-wrap :global(svg line),
    .icon-wrap :global(svg circle) {
      stroke-dasharray: 200;
      stroke-dashoffset: 200;
      transition:
        stroke-dashoffset 0.9s 0.35s cubic-bezier(0.19, 1, 0.22, 1);
    }

    article.active .icon-wrap :global(svg path),
    article.active .icon-wrap :global(svg polyline),
    article.active .icon-wrap :global(svg line),
    article.active .icon-wrap :global(svg circle) {
      stroke-dashoffset: 0;
    }
  }
</style>

---
import { Check } from "lucide-astro";

export interface Props {
    icon: string;
    title: string;
    items: string[];
    highlight?: string;
    featured?: boolean;
    index?: number;
    className?: string;
}

const {
    icon,
    title,
    items,
    highlight,
    featured = false,
    index,
    className = "",
} = Astro.props;

import {
    Globe,
    ShoppingBag,
    Settings,
    Bot,
    Rocket,
    Wrench,
    Zap,
    Lock,
    Shield,
} from "lucide-astro";

const iconMap: Record<string, any> = {
    globe: Globe,
    "shopping-bag": ShoppingBag,
    settings: Settings,
    bot: Bot,
    rocket: Rocket,
    wrench: Wrench,
    zap: Zap,
    lock: Lock,
    shield: Shield,
};

const IconComponent = iconMap[icon] || Globe;
const num =
    typeof index === "number" ? String(index + 1).padStart(2, "0") : null;
---

<article
    class={`glass-card reveal group relative overflow-hidden ${
        featured
            ? "p-7 md:p-10 md:grid md:grid-cols-[1.1fr_1fr] md:gap-10 md:items-center"
            : "p-6 md:p-8 h-full flex flex-col"
    } ${className}`}
>
    <!-- Featured: accent corner glow -->
    {
        featured && (
            <div
                class="absolute -top-20 -right-20 w-64 h-64 rounded-full bg-primary-300/15 blur-3xl pointer-events-none"
                aria-hidden="true"
            />
        )
    }

    <div class="relative">
        <div class="flex items-center justify-between mb-5">
            <div
                class="icon-wrap w-12 h-12 rounded-xl bg-primary-600/10 flex items-center justify-center relative"
            >
                <IconComponent class="w-6 h-6 text-primary-600 relative z-10" />
            </div>
            {
                num && (
                    <span class="text-sm font-bold tracking-widest text-dark-500 tabular-nums">
                        {num}
                    </span>
                )
            }
        </div>

        {highlight && <p class="eyebrow mb-2">{highlight}</p>}
        <h3
            class={`text-main mb-0 ${featured ? "text-2xl md:text-3xl" : "text-xl"}`}
        >
            {title}
        </h3>
    </div>

    <!-- Items List -->
    <ul class={`space-y-2.5 relative ${featured ? "mt-2 md:mt-0" : "mt-5"}`}>
        {
            items.map((item) => (
                <li class="flex items-start gap-2.5 text-secondary text-[0.95rem]">
                    <span class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-accent-100 flex items-center justify-center">
                        <Check class="w-3 h-3 text-accent-700" />
                    </span>
                    <span>{item}</span>
                </li>
            ))
        }
    </ul>
</article>

<style>
    /*
   * Icon draw-in: animate SVG strokes in .icon-wrap when card enters viewport.
   */
    @media (prefers-reduced-motion: no-preference) {
        .icon-wrap :global(svg path),
        .icon-wrap :global(svg polyline),
        .icon-wrap :global(svg line),
        .icon-wrap :global(svg circle),
        .icon-wrap :global(svg rect) {
            stroke-dasharray: 200;
            stroke-dashoffset: 200;
            transition: stroke-dashoffset 0.9s 0.35s cubic-bezier(0.19, 1, 0.22, 1);
        }

        article.active .icon-wrap :global(svg path),
        article.active .icon-wrap :global(svg polyline),
        article.active .icon-wrap :global(svg line),
        article.active .icon-wrap :global(svg circle),
        article.active .icon-wrap :global(svg rect) {
            stroke-dashoffset: 0;
        }
    }
</style>

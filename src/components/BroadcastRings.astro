---
// Anneaux de diffusion émanant du centre de leur conteneur (la planète).
// Le conteneur parent doit être `position: relative`.
---

<div class="broadcast-rings" aria-hidden="true">
  <span class="br" style="--d:0s"></span>
  <span class="br" style="--d:1s"></span>
  <span class="br" style="--d:2s"></span>
</div>

<style>
  .broadcast-rings {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    pointer-events: none;
    z-index: 0;
  }

  .br {
    position: absolute;
    top: 0;
    left: 0;
    width: 6rem;
    height: 6rem;
    margin-top: -3rem;
    margin-left: -3rem;
    border: 1px solid oklch(0.58 0.190 250);
    border-radius: 9999px;
    opacity: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .br {
      animation: broadcast 3s var(--d, 0s) ease-out infinite;
    }

    @keyframes broadcast {
      0% {
        transform: scale(0.55);
        opacity: 0.5;
      }
      100% {
        transform: scale(2.6);
        opacity: 0;
      }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .br {
      opacity: 0.1;
      transform: scale(1.4);
    }
  }
</style>

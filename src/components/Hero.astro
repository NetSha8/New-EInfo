---
import { ArrowRight, MapPin, Clock, UserCheck, ShieldCheck } from "lucide-astro";
import HeroTerminal from "./HeroTerminal.astro";
import AnimatedNetworkBg from "./AnimatedNetworkBg.astro";

const reassurances = [
    { icon: Clock, label: "Intervention sous 48h" },
    { icon: UserCheck, label: "Un seul interlocuteur" },
    { icon: ShieldCheck, label: "Sur place ou à distance" },
];
---

<section
    class="relative min-h-screen flex items-center pt-24 md:pt-20 overflow-hidden"
>
    <!-- Backdrop: subtle hairline grid + network topology -->
    <div class="absolute inset-0 grid-texture pointer-events-none"></div>
    <AnimatedNetworkBg />

    <!-- Soft accent glow, top-left -->
    <div
        class="absolute -top-32 -left-32 w-[32rem] h-[32rem] rounded-full bg-primary-300/20 blur-3xl pointer-events-none"
        aria-hidden="true"
    >
    </div>

    <!-- Content -->
    <div class="container-custom relative z-10 py-12 md:py-20">
        <div
            class="grid grid-cols-1 lg:grid-cols-[1.15fr_0.85fr] gap-10 lg:gap-12 items-center"
        >
            <!-- Left: Text Content -->
            <div>
                <!-- Eyebrow -->
                <p
                    class="eyebrow mb-6 animate-slide-up"
                    style="animation-delay: 0.05s;"
                >
                    Technicien informatique · Pyrénées-Orientales
                </p>

                <!-- Title -->
                <h1
                    class="mb-6 animate-slide-up"
                    style="animation-delay: 0.1s;"
                >
                    Votre informatique,
                    <span class="text-highlight">stable et sans surprise.</span>
                </h1>

                <!-- Subtitle -->
                <p
                    class="text-lg text-secondary mb-7 max-w-xl animate-slide-up"
                    style="animation-delay: 0.2s;"
                >
                    Serveurs, sites web, sécurité et dépannage : je gère toute la
                    chaîne technique de votre entreprise pour qu'elle tourne
                    seule, sans que vous ayez à y penser.
                </p>

                <!-- Location -->
                <p
                    class="flex items-start gap-2 text-secondary mb-8 animate-slide-up text-sm"
                    style="animation-delay: 0.3s;"
                >
                    <MapPin class="w-5 h-5 text-accent-600 flex-shrink-0 mt-0.5" />
                    <span
                        >À <strong class="text-main">Rivesaltes</strong>,
                        <strong class="text-main">Perpignan</strong> et dans les
                        <strong class="text-main">Pyrénées-Orientales</strong> ·
                        à distance partout en
                        <strong class="text-main">France</strong></span
                    >
                </p>

                <!-- CTAs -->
                <div
                    class="flex flex-col sm:flex-row gap-3 animate-slide-up"
                    style="animation-delay: 0.4s;"
                >
                    <a href="/contact/" class="btn-primary justify-center">
                        <span>Décrire mon problème</span>
                        <ArrowRight class="w-5 h-5" />
                    </a>
                    <a href="/services/" class="btn-secondary justify-center">
                        <span>Voir mes services</span>
                    </a>
                </div>

                <!-- Reassurance row -->
                <ul
                    class="flex flex-wrap gap-x-6 gap-y-3 mt-9 pt-7 border-t border-dark-700 animate-slide-up"
                    style="animation-delay: 0.5s;"
                >
                    {
                        reassurances.map((r) => (
                            <li class="flex items-center gap-2 text-sm font-medium text-main">
                                <r.icon class="w-4.5 h-4.5 text-primary-600" />
                                <span>{r.label}</span>
                            </li>
                        ))
                    }
                </ul>
            </div>

            <!-- Right: Animated Terminal -->
            <div
                class="hidden lg:flex justify-center items-center animate-fade-in"
                style="animation-delay: 0.5s;"
            >
                <HeroTerminal />
            </div>
        </div>
    </div>

    <!-- Scroll Indicator -->
    <div
        class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden md:block z-20"
    >
        <a
            href="#services"
            class="flex flex-col items-center gap-2 text-secondary hover:text-primary-600 transition-colors group"
            aria-label="Voir la suite"
        >
            <div class="mouse-container">
                <svg
                    class="w-6 h-10"
                    viewBox="0 0 24 40"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <rect
                        x="1"
                        y="1"
                        width="22"
                        height="38"
                        rx="11"
                        stroke="currentColor"
                        stroke-width="2"
                        class="group-hover:stroke-primary-600 transition-colors"></rect>
                    <rect
                        class="scroll-wheel"
                        x="10"
                        y="8"
                        width="4"
                        height="8"
                        rx="2"
                        fill="currentColor"></rect>
                </svg>
            </div>
        </a>
    </div>
</section>

<style>
    .mouse-container {
        animation: float 2s ease-in-out infinite;
    }

    .scroll-wheel {
        animation: scroll-wheel 1.5s ease-in-out infinite;
    }

    @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-5px); }
    }

    @keyframes scroll-wheel {
        0% { opacity: 1; transform: translateY(0); }
        50% { opacity: 0.5; transform: translateY(8px); }
        100% { opacity: 0; transform: translateY(12px); }
    }

    @media (prefers-reduced-motion: reduce) {
        .mouse-container, .scroll-wheel { animation: none; }
    }
</style>

---
import { ArrowRight, MapPin } from "lucide-astro";
import PixelatedCanvas from "./PixelatedCanvas";
---

<section
    class="relative min-h-screen flex items-center pt-20 md:pt-0 overflow-hidden"
>
    <!-- Background - Flat solid -->
    <div class="absolute inset-0 bg-dark-950"></div>

    <!-- Subtle pattern overlay for texture -->
    <div
        class="absolute inset-0 opacity-[0.02]"
        style="background-image: url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNDAiIGhlaWdodD0iNDAiIHZpZXdCb3g9IjAgMCA0MCA0MCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48ZyBmaWxsPSIjZmZmIiBmaWxsLXJ1bGU9ImV2ZW5vZGQiPjxjaXJjbGUgY3g9IjIwIiBjeT0iMjAiIHI9IjEiLz48L2c+PC9zdmc+');"
    >
    </div>

    <!-- Content -->
    <div class="container-custom relative z-10 py-12 md:py-20">
        <div
            class="grid grid-cols-1 lg:grid-cols-[2fr_1fr] gap-8 lg:gap-8 items-center"
        >
            <!-- Left: Text Content -->
            <div>
                <!-- Title -->
                <h1
                    class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight animate-slide-up text-main"
                    style="animation-delay: 0.1s;"
                >
                    Dépannage informatique à Rivesaltes et dans les Pyrénées-Orientales.<br />
                    <span class="text-primary-400">Dépannage, site web, serveur et sécurité.</span>
                </h1>

                <!-- Subtitle -->
                <p
                    class="text-lg md:text-xl text-secondary mb-4 max-w-2xl animate-slide-up"
                    style="animation-delay: 0.2s;"
                >
                    Votre site web qui rame, votre serveur mal configuré, votre poste infecté, votre messagerie qui part en spam : je m'en occupe directement.
                </p>

                <!-- Location -->
                <p
                    class="flex items-center gap-2 text-secondary mb-8 animate-slide-up"
                    style="animation-delay: 0.3s;"
                >
                    <MapPin class="w-5 h-5 text-primary-400" />
                    <span>Intervention à <strong class="text-main">Rivesaltes</strong>, <strong class="text-main">Perpignan</strong> et dans les <strong class="text-main">Pyrénées-Orientales</strong> · À distance partout en <strong class="text-main">France</strong></span>
                </p>

                <!-- CTAs -->
                <div
                    class="flex flex-col sm:flex-row gap-3 animate-slide-up"
                    style="animation-delay: 0.4s;"
                >
                    <a
                        href="/contact"
                        class="btn-primary justify-center text-base px-4 py-2"
                    >
                        <ArrowRight class="w-5 h-5" />
                        <span>Décrire mon problème</span>
                    </a>
                    <a
                        href="/services"
                        class="btn-secondary justify-center text-base px-4 py-2"
                    >
                        <span>Voir mes services</span>
                    </a>
                </div>
            </div>

            <!-- Right: Pixelated Logo -->
            <div
                class="hidden lg:flex justify-end items-center animate-slide-up -mr-8"
                style="animation-delay: 0.6s;"
            >
                <div class="relative pixelated-logo-container p-12">
                    <!-- Glow effect -->
                    <div
                        class="absolute inset-0 bg-primary-400/20 blur-3xl rounded-full scale-75"
                    >
                    </div>

                    <PixelatedCanvas
                        client:visible
                        src="/images/logo.svg"
                        width={360}
                        height={360}
                        cellSize={5}
                        dotScale={0.9}
                        interactive={true}
                        distortionStrength={25}
                        distortionRadius={80}
                    />
                </div>
            </div>
        </div>
    </div>

    <!-- Scroll Indicator - Animated Mouse -->
    <div
        class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden md:block z-20"
    >
        <a
            href="#services"
            class="flex flex-col items-center gap-2 text-secondary hover:text-primary-400 transition-colors group"
            aria-label="Scroll down"
        >
            <!-- Mouse Container -->
            <div class="mouse-container">
                <svg
                    class="w-6 h-10"
                    viewBox="0 0 24 40"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <!-- Mouse Body -->
                    <rect
                        x="1"
                        y="1"
                        width="22"
                        height="38"
                        rx="11"
                        stroke="currentColor"
                        stroke-width="2"
                        class="group-hover:stroke-primary-400 transition-colors"
                    ></rect>
                    <!-- Scroll Wheel (animated) -->
                    <rect
                        class="scroll-wheel"
                        x="10"
                        y="8"
                        width="4"
                        height="8"
                        rx="2"
                        fill="currentColor"></rect>
                </svg>
            </div>
        </a>
    </div>
</section>

<style>
    .mouse-container {
        animation: float 2s ease-in-out infinite;
    }

    .scroll-wheel {
        animation: scroll-wheel 1.5s ease-in-out infinite;
    }

    @keyframes float {
        0%,
        100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-5px);
        }
    }

    @keyframes scroll-wheel {
        0% {
            opacity: 1;
            transform: translateY(0);
        }
        50% {
            opacity: 0.5;
            transform: translateY(8px);
        }
        100% {
            opacity: 0;
            transform: translateY(12px);
        }
    }

    .pixelated-logo-container {
        /* Static - no floating animation */
    }
</style>

---
import { Wrench, CheckCircle2 } from "lucide-astro";

const techCategories = [
    {
        title: "Développement Web",
        techs: ["TypeScript", "PHP", "WordPress"],
    },
    {
        title: "Systèmes & Automatisation",
        techs: [
            "Linux (Debian/Ubuntu)",
            "Bash",
            "Rust (apprentissage actif)",
            "Automatisation",
        ],
    },
    {
        title: "Plateforme & Déploiement",
        techs: [
            "Docker",
            "VPS Linux",
            "Kamal",
            "GitHub Actions",
            "Nginx",
        ],
    },
    {
        title: "CMS & Frameworks",
        techs: ["WordPress", "Astro", "SvelteKit", "TypeScript"],
    },
];
---

<section id="technologies" class="py-20 md:py-28 bg-dark-900">
    <div class="container-custom">
        <!-- Section Header -->
        <div class="text-center mb-12 md:mb-16">
            <div
                class="w-14 h-14 rounded-xl bg-primary-600/10 flex items-center justify-center mx-auto mb-4"
            >
                <Wrench class="w-7 h-7 text-primary-400" />
            </div>
            <h2 class="section-title text-main">Technologies utilisées</h2>
            <p class="text-secondary max-w-2xl mx-auto">
                Une stack orientée production: développement web, infrastructure Linux,
                automatisation et déploiement.
            </p>
        </div>

        <!-- Tech Categories - Glass Cards -->
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
            {
                techCategories.map((category, index) => (
                    <div
                        class={`glass-card glass-card--static reveal p-6 md:p-8 text-left delay-${(index + 1) * 100} hover:-translate-y-1 transition-transform`}
                    >
                        <h3 class="text-xl font-bold text-main mb-6">
                            {category.title}
                        </h3>
                        <ul class="flex flex-col gap-4">
                            {category.techs.map((tech) => (
                                <li class="flex items-start gap-3">
                                    <CheckCircle2 class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" />
                                    <span class="text-secondary font-medium">{tech}</span>
                                </li>
                            ))}
                        </ul>
                    </div>
                ))
            }
        </div>
    </div>
</section>

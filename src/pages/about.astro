---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { CheckCircle2, ArrowRight } from "lucide-astro";

const personSchema = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Elian",
    jobTitle: "Technicien informatique indépendant",
    worksFor: {
        "@id": "https://einformatique.fr/#business",
    },
    address: {
        "@type": "PostalAddress",
        addressLocality: "Rivesaltes",
        postalCode: "66600",
        addressRegion: "Occitanie",
        addressCountry: "FR",
    },
    knowsAbout: [
        "Dépannage informatique",
        "Administration Linux",
        "Sécurité informatique",
        "Création de site web",
        "Hébergement VPS",
    ],
    url: "https://einformatique.fr/about",
};
---

<BaseLayout
    title="Elian — Site web, infrastructure et sécurité à Perpignan | E Informatique"
    description="Elian accompagne les TPE/PME à Perpignan et dans les Pyrénées-Orientales sur le site web, l'infrastructure VPS, l'automatisation et la sécurité."
    jsonLd={personSchema}
>
    <Header />

    <main class="pt-24 pb-20 overflow-hidden">
        <!-- Hero Section -->
        <section class="relative py-12 md:py-20">
            <div class="container-custom">
                <div class="max-w-4xl space-y-8">
                    <h1
                        class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-main reveal"
                    >
                        Site web, infrastructure et sécurité à Perpignan
                    </h1>
                    <div
                        class="pt-8 text-lg text-main/80 space-y-4 reveal delay-200 text-left max-w-3xl leading-relaxed"
                    >
                        <p>
                            Je m'appelle Elian, 29 ans. J'interviens pour les TPE/PME à Perpignan, Rivesaltes et dans les Pyrénées-Orientales (66).
                        </p>
                        <p>
                            Mon métier : construire des systèmes informatiques autonomes. Le principe est simple : détecter tôt, corriger vite, éviter la panne visible côté client.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Background decoration -->
            <div
                class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-primary-500/10 rounded-full blur-[100px] -z-10 pointer-events-none"
            >
            </div>
        </section>

        <!-- Section: Parcours technique -->
        <section class="py-16 md:py-24 bg-dark-900/50">
            <div class="container-custom">
                <div class="max-w-3xl space-y-8 reveal">
                    <h2 class="section-title text-3xl md:text-4xl mb-12">
                        Parcours technique
                    </h2>
                    <div
                        class="space-y-4 text-secondary text-lg leading-relaxed"
                    >
                        <p>
                            J'ai commencé par l'administration système : postes de travail, réseaux locaux, serveurs Linux et incidents du quotidien en entreprise.
                        </p>
                        <p>
                            Ensuite, j'ai industrialisé les interventions avec l'automatisation : scripts Python, APIs FastAPI, déploiements Docker sur VPS 24/7, supervision continue et alertes Telegram.
                        </p>
                        <p>
                            Aujourd'hui, j'interviens sur l'ensemble du cycle technique : site web, serveur, sécurité et surveillance automatique, sans renvoyer vers trois prestataires différents.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Section: Stack concrète -->
        <section class="py-16 md:py-24">
            <div class="container-custom">
                <div class="max-w-3xl space-y-10 reveal">
                    <h2 class="section-title text-3xl md:text-4xl mb-12">
                        Stack concrète
                    </h2>
                    <div
                        class="space-y-6 text-lg text-secondary leading-relaxed"
                    >
                        <p>
                            Je travaille avec une stack volontairement robuste : Python pour l'automatisation et les scripts métier, Docker + Linux pour des environnements stables, SQL pour la donnée utile, CI/CD pour déployer proprement, monitoring + alerting Telegram pour être prévenu avant vous.
                        </p>
                        <p class="text-2xl text-main font-semibold">
                            Objectif : que vos outils tournent en continu sans dépendre d'actions manuelles répétitives.
                        </p>
                        <p>
                            Concrètement, cela donne des sauvegardes vérifiées, des déploiements reproductibles, des alertes utiles et un plan d'action simple quand un incident arrive.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Section: À qui je m'adresse -->
        <section class="py-16 md:py-24 bg-dark-900/50">
            <div class="container-custom">
                <div class="max-w-5xl">
                    <h2 class="section-title text-3xl md:text-4xl mb-16 reveal">
                        À qui je m'adresse
                    </h2>

                    <div class="grid md:grid-cols-3 gap-2 reveal delay-100">
                        <!-- Card 1 -->
                        <div
                            class="glass-card glass-card--static card-glow p-8 flex flex-col h-full"
                        >
                            <div
                                class="w-14 h-14 rounded-full bg-primary-500/20 flex items-center justify-center mb-6 text-primary-400 font-bold text-2xl"
                            >
                                1
                            </div>
                            <h3 class="text-2xl font-bold mb-4">TPE &amp; PME locales</h3>
                            <p class="text-secondary text-lg">
                                Structures sans DSI interne à Perpignan et dans le 66, qui veulent un système informatique fiable sans multiplier les interlocuteurs.
                            </p>
                        </div>
                        <!-- Card 2 -->
                        <div
                            class="glass-card glass-card--static card-glow p-8 flex flex-col h-full"
                        >
                            <div
                                class="w-14 h-14 rounded-full bg-primary-500/20 flex items-center justify-center mb-6 text-primary-400 font-bold text-2xl"
                            >
                                2
                            </div>
                            <h3 class="text-2xl font-bold mb-4">Artisans et commerçants</h3>
                            <p class="text-secondary text-lg">
                                Activités avec un site qui doit rester accessible, rapide et sécurisé pour générer des demandes en continu.
                            </p>
                        </div>
                        <!-- Card 3 -->
                        <div
                            class="glass-card glass-card--static card-glow p-8 flex flex-col h-full"
                        >
                            <div
                                class="w-14 h-14 rounded-full bg-primary-500/20 flex items-center justify-center mb-6 text-primary-400 font-bold text-2xl"
                            >
                                3
                            </div>
                            <h3 class="text-2xl font-bold mb-4">PME orientées continuité</h3>
                            <p class="text-secondary text-lg">
                                Équipes qui veulent de la surveillance automatique pour anticiper les incidents au lieu de les subir.
                            </p>
                        </div>
                    </div>
                    <div
                        class="mt-16 text-xl text-secondary reveal delay-200 max-w-3xl"
                    >
                        <p>
                            J'interviens à <strong
                                class="text-main">Rivesaltes, Perpignan et sa périphérie</strong
                            >, mais j'accompagne aussi mes clients <strong
                                class="text-main">partout en France à distance</strong
                            >.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Section: Collaboration -->
        <section class="py-16 md:py-24 bg-dark-900/50">
            <div class="container-custom">
                <div class="max-w-4xl reveal">
                    <h2 class="section-title text-3xl md:text-4xl mb-12">
                        Simplicité, performance, sens du détail
                    </h2>
                    <div
                        class="bg-dark-800/50 rounded-2xl p-8 md:p-12    -white/5"
                    >
                        <p class="text-xl mb-8 font-medium text-main">
                            Je m’engage à :
                        </p>
                        <div
                            class="grid md:grid-cols-2 gap-y-6 gap-x-8 text-left max-w-3xl"
                        >
                            <div class="flex items-center gap-4">
                                <CheckCircle2
                                    class="w-6 h-6 text-green-400 flex-shrink-0"
                                />
                                <span class="text-secondary text-lg"
                                    >Comprendre votre contrainte métier avant la solution</span
                                >
                            </div>
                            <div class="flex items-center gap-4">
                                <CheckCircle2
                                    class="w-6 h-6 text-green-400 flex-shrink-0"
                                />
                                <span class="text-secondary text-lg"
                                    >Concevoir une architecture lisible et maintenable</span
                                >
                            </div>
                            <div class="flex items-center gap-4">
                                <CheckCircle2
                                    class="w-6 h-6 text-green-400 flex-shrink-0"
                                />
                                <span class="text-secondary text-lg"
                                    >Automatiser les tâches répétitives qui créent du risque</span
                                >
                            </div>
                            <div class="flex items-center gap-4">
                                <CheckCircle2
                                    class="w-6 h-6 text-green-400 flex-shrink-0"
                                />
                                <span class="text-secondary text-lg"
                                    >Mesurer ce qui compte avec un monitoring clair</span
                                >
                            </div>
                            <div class="flex items-center gap-4 md:col-span-2">
                                <CheckCircle2
                                    class="w-6 h-6 text-green-400 flex-shrink-0"
                                />
                                <span class="text-secondary text-lg"
                                    >Documenter ce qui est fait pour rester autonome dans le temps</span
                                >
                            </div>
                        </div>
                        <p class="mt-10 text-xl text-main leading-relaxed">
                            Exemple concret : au lieu de vérifier manuellement chaque matin si le site, les sauvegardes et les emails fonctionnent, vous recevez une alerte uniquement quand une action est nécessaire. Le reste tourne en arrière-plan.
                        </p>
                        <p class="mt-6 text-2xl md:text-3xl font-bold text-main leading-tight">
                            Je construis les systèmes. Vous gérez votre métier.
                        </p>
                        <div class="mt-10">
                            <a
                                href="/contact"
                                class="btn-primary text-lg px-8 py-4"
                            >
                                Travaillons ensemble
                                <ArrowRight class="w-5 h-5" />
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</BaseLayout>

<style>
    .card-glow {
        position: relative;
        overflow: hidden;
    }
    .card-glow::before {
        content: '';
        position: absolute;
        top: var(--glow-y, -100px);
        left: var(--glow-x, -100px);
        width: 250px;
        height: 250px;
        background: radial-gradient(circle, rgba(51, 133, 255, 0.08) 0%, transparent 70%);
        transform: translate(-50%, -50%);
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.3s ease;
        z-index: 0;
    }
    .card-glow:hover::before {
        opacity: 1;
    }
    .card-glow > * {
        position: relative;
        z-index: 1;
    }
</style>

<script>
    document.querySelectorAll('.card-glow').forEach((card) => {
        card.addEventListener('mousemove', (e) => {
            const el = card as HTMLElement;
            const rect = el.getBoundingClientRect();
            const mEvent = e as MouseEvent;
            el.style.setProperty('--glow-x', `${mEvent.clientX - rect.left}px`);
            el.style.setProperty('--glow-y', `${mEvent.clientY - rect.top}px`);
        });
    });
</script>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { CheckCircle2, ArrowRight } from "lucide-astro";

const personSchema = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Elian",
    jobTitle: "Technicien informatique indépendant",
    worksFor: {
        "@id": "https://einformatique.fr/#business",
    },
    address: {
        "@type": "PostalAddress",
        addressLocality: "Rivesaltes",
        postalCode: "66600",
        addressRegion: "Occitanie",
        addressCountry: "FR",
    },
    knowsAbout: [
        "Dépannage informatique",
        "Administration Linux",
        "Sécurité informatique",
        "Création de site web",
        "Hébergement VPS",
    ],
    url: "https://einformatique.fr/about",
};
---

<BaseLayout
    title="Elian — Technicien Informatique à Rivesaltes | E Informatique"
    description="Technicien informatique indépendant à Rivesaltes (66600). J'accompagne les TPE/PME des Pyrénées-Orientales sur le dépannage, la sécurité, les sites web et les VPS."
    jsonLd={personSchema}
>
    <Header />

    <main class="pt-24 pb-20 overflow-hidden">
        <!-- Hero Section -->
        <section class="relative py-12 md:py-20">
            <div class="container-custom">
                <div class="max-w-4xl space-y-8">
                    <h1
                        class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-main reveal"
                    >
                        Technicien informatique indépendant à Rivesaltes
                    </h1>
                    <div
                        class="pt-8 text-lg text-main/80 space-y-4 reveal delay-200 text-left max-w-3xl leading-relaxed"
                    >
                        <p>
                            Je m'appelle Elian. J'interviens pour les TPE/PME à Rivesaltes, Perpignan et dans les Pyrénées-Orientales.
                        </p>
                        <p>
                            Mon socle, c'est la maintenance informatique et l'administration système. Concrètement, je gère des postes clients, des serveurs Linux, des sauvegardes et des incidents de sécurité du quotidien.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Background decoration -->
            <div
                class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-primary-500/10 rounded-full blur-[100px] -z-10 pointer-events-none"
            >
            </div>
        </section>

        <!-- Section: Pourquoi cette approche ? -->
        <section class="py-16 md:py-24 bg-dark-900/50">
            <div class="container-custom">
                <div class="max-w-3xl space-y-8 reveal">
                    <h2 class="section-title text-3xl md:text-4xl mb-12">
                        Pourquoi cette approche ?
                    </h2>
                    <div
                        class="space-y-4 text-secondary text-lg leading-relaxed"
                    >
                        <p>
                            J'ai construit mon expérience sur des cas concrets : machines instables, réseaux mal configurés, sites lents ou non maintenus, serveurs VPS mal sécurisés.
                        </p>
                        <p>
                            Cette approche terrain permet d'aller vite : diagnostiquer, corriger et expliquer clairement ce qui a été fait, sans multiplier les intermédiaires.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Section: Comment je travaille -->
        <section class="py-16 md:py-24">
            <div class="container-custom">
                <div class="max-w-3xl space-y-10 reveal">
                    <h2 class="section-title text-3xl md:text-4xl mb-12">
                        Comment je travaille
                    </h2>
                    <div
                        class="space-y-6 text-lg text-secondary leading-relaxed"
                    >
                        <p>
                            Je préfère les solutions simples qui durent aux solutions complexes qui impressionnent.
                        </p>
                        <p class="text-2xl text-main font-semibold">
                            Avant de proposer quoi que ce soit, je regarde votre contexte réel : budget, contraintes et urgence métier.
                        </p>
                        <p>
                            Une TPE n'a pas besoin d'une architecture compliquée. Elle a besoin d'un système stable, sauvegardé et facile à faire évoluer.
                        </p>
                        <p>
                            Je vous propose ce qui correspond à votre besoin, pas la solution la plus chère ou la plus technique.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Section: À qui je m'adresse -->
        <section class="py-16 md:py-24 bg-dark-900/50">
            <div class="container-custom">
                <div class="max-w-5xl">
                    <h2 class="section-title text-3xl md:text-4xl mb-16 reveal">
                        À qui je m'adresse
                    </h2>

                    <div class="grid md:grid-cols-3 gap-2 reveal delay-100">
                        <!-- Card 1 -->
                        <div
                            class="glass-card glass-card--static card-glow p-8 flex flex-col h-full"
                        >
                            <div
                                class="w-14 h-14 rounded-full bg-primary-500/20 flex items-center justify-center mb-6 text-primary-400 font-bold text-2xl"
                            >
                                1
                            </div>
                            <h3 class="text-2xl font-bold mb-4">TPE &amp; PME locales</h3>
                            <p class="text-secondary text-lg">
                                Restaurants, artisans, commerçants, cabinets à Perpignan et dans les Pyrénées-Orientales, qui cherchent un prestataire disponible et fiable pour leurs besoins informatiques.
                            </p>
                        </div>
                        <!-- Card 2 -->
                        <div
                            class="glass-card glass-card--static card-glow p-8 flex flex-col h-full"
                        >
                            <div
                                class="w-14 h-14 rounded-full bg-primary-500/20 flex items-center justify-center mb-6 text-primary-400 font-bold text-2xl"
                            >
                                2
                            </div>
                            <h3 class="text-2xl font-bold mb-4">Structures en croissance</h3>
                            <p class="text-secondary text-lg">
                                Équipes qui veulent fiabiliser leur informatique sans recruter un service interne complet.
                            </p>
                        </div>
                        <!-- Card 3 -->
                        <div
                            class="glass-card glass-card--static card-glow p-8 flex flex-col h-full"
                        >
                            <div
                                class="w-14 h-14 rounded-full bg-primary-500/20 flex items-center justify-center mb-6 text-primary-400 font-bold text-2xl"
                            >
                                3
                            </div>
                            <h3 class="text-2xl font-bold mb-4">Particuliers</h3>
                            <p class="text-secondary text-lg">
                                Ceux qui ont besoin d'un dépannage rapide et d'explications claires, sans jargon.
                            </p>
                        </div>
                    </div>
                    <div
                        class="mt-16 text-xl text-secondary reveal delay-200 max-w-3xl"
                    >
                        <p>
                            J'interviens à <strong
                                class="text-main">Rivesaltes, Perpignan et sa périphérie</strong
                            >, mais j'accompagne aussi mes clients <strong
                                class="text-main">partout en France à distance</strong
                            >.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Section: Collaboration -->
        <section class="py-16 md:py-24 bg-dark-900/50">
            <div class="container-custom">
                <div class="max-w-4xl reveal">
                    <h2 class="section-title text-3xl md:text-4xl mb-12">
                        Une collaboration simple, claire et efficace
                    </h2>
                    <div
                        class="bg-dark-800/50 rounded-2xl p-8 md:p-12    -white/5"
                    >
                        <p class="text-xl mb-8 font-medium text-main">
                            Je m’engage à :
                        </p>
                        <div
                            class="grid md:grid-cols-2 gap-y-6 gap-x-8 text-left max-w-3xl"
                        >
                            <div class="flex items-center gap-4">
                                <CheckCircle2
                                    class="w-6 h-6 text-green-400 flex-shrink-0"
                                />
                                <span class="text-secondary text-lg"
                                    >Comprendre votre besoin réel</span
                                >
                            </div>
                            <div class="flex items-center gap-4">
                                <CheckCircle2
                                    class="w-6 h-6 text-green-400 flex-shrink-0"
                                />
                                <span class="text-secondary text-lg"
                                    >Proposer une solution adaptée</span
                                >
                            </div>
                            <div class="flex items-center gap-4">
                                <CheckCircle2
                                    class="w-6 h-6 text-green-400 flex-shrink-0"
                                />
                                <span class="text-secondary text-lg"
                                    >Réponse sous 24h, intervention rapide</span
                                >
                            </div>
                            <div class="flex items-center gap-4">
                                <CheckCircle2
                                    class="w-6 h-6 text-green-400 flex-shrink-0"
                                />
                                <span class="text-secondary text-lg"
                                    >Expliquer les choses simplement</span
                                >
                            </div>
                            <div class="flex items-center gap-4 md:col-span-2">
                                <CheckCircle2
                                    class="w-6 h-6 text-green-400 flex-shrink-0"
                                />
                                <span class="text-secondary text-lg"
                                    >Assurer un suivi transparent</span
                                >
                            </div>
                        </div>
                        <p class="mt-10 text-xl text-main leading-relaxed">
                            Mon objectif est simple : que ça fonctionne, que vous compreniez ce qui a été fait, et que vous puissiez me joindre si quelque chose change.
                        </p>
                        <div class="mt-10">
                            <a
                                href="/contact"
                                class="btn-primary text-lg px-8 py-4"
                            >
                                Travaillons ensemble
                                <ArrowRight class="w-5 h-5" />
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</BaseLayout>

<style>
    .card-glow {
        position: relative;
        overflow: hidden;
    }
    .card-glow::before {
        content: '';
        position: absolute;
        top: var(--glow-y, -100px);
        left: var(--glow-x, -100px);
        width: 250px;
        height: 250px;
        background: radial-gradient(circle, rgba(51, 133, 255, 0.08) 0%, transparent 70%);
        transform: translate(-50%, -50%);
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.3s ease;
        z-index: 0;
    }
    .card-glow:hover::before {
        opacity: 1;
    }
    .card-glow > * {
        position: relative;
        z-index: 1;
    }
</style>

<script>
    document.querySelectorAll('.card-glow').forEach((card) => {
        card.addEventListener('mousemove', (e) => {
            const el = card as HTMLElement;
            const rect = el.getBoundingClientRect();
            const mEvent = e as MouseEvent;
            el.style.setProperty('--glow-x', `${mEvent.clientX - rect.left}px`);
            el.style.setProperty('--glow-y', `${mEvent.clientY - rect.top}px`);
        });
    });
</script>

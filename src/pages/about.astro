---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { CheckCircle2, ArrowRight } from "lucide-astro";
import { Wordpress, Linux, Gnubash, Rust } from "simple-icons-astro";
---

<BaseLayout
    title="À propos | Elian Développeur Web & Administrateur Systèmes"
    description="Parcours d'un technicien informatique en transition vers un profil ingénierie systèmes : web, Linux, automatisation et sécurité infrastructure."
>
    <Header />

    <main class="pt-24 pb-20 overflow-hidden">
        <!-- Hero Section -->
        <section class="relative py-12 md:py-20">
            <div class="container-custom">
                <div class="max-w-4xl space-y-8">
                    <h1
                        class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-main reveal"
                    >
                        À propos
                    </h1>
                    <p
                        class="text-xl md:text-2xl text-secondary font-medium reveal delay-100"
                    >
                        Elian Technicien informatique, développeur web & administrateur systèmes
                    </p>
                    <div
                        class="pt-8 text-lg text-main/80 space-y-4 reveal delay-200 text-left max-w-3xl leading-relaxed"
                    >
                        <p>
                            Je m'appelle Elian. J'accompagne les solopreneurs,
                            PME et entreprises tech sur des besoins concrets :
                            sites web fiables, maintenance, déploiement et
                            infrastructure Linux.
                        </p>
                        <p>
                            Mon parcours de technicien informatique m'a donné
                            une base solide en systèmes et exploitation.
                            Aujourd'hui, je combine cette base avec le
                            développement web pour intervenir à la fois sur le
                            code et sur le système qui le fait tourner.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Background decoration -->
            <div
                class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-primary-500/10 rounded-full blur-[100px] -z-10 pointer-events-none"
            >
            </div>
        </section>

        <!-- Section: De la technique pure au service direct -->
        <section class="py-16 md:py-24 bg-dark-900/50">
            <div class="container-custom">
                <div class="grid md:grid-cols-2 gap-12 items-center">
                    <div class="order-2 md:order-1 reveal">
                        <h2 class="section-title text-3xl md:text-4xl mb-12">
                            De la technique pure au service direct
                        </h2>
                        <div
                            class="space-y-4 text-secondary text-lg leading-relaxed"
                        >
                            <p>
                                Mon parcours m'a appris à traiter les sujets
                                d'exploitation que l'on voit peu en surface :
                                serveurs, configuration système, déploiement,
                                sécurité et automatisation.
                            </p>
                            <p>
                                Aujourd'hui, je mets cette approche au service
                                de mes clients pour livrer :
                            </p>
                            <ul class="space-y-3 mt-8">
                                <li class="flex items-start gap-3">
                                    <CheckCircle2
                                        class="w-6 h-6 text-primary-400 shrink-0 mt-0.5"
                                    />
                                    <span
                                        >des sites web performants (WordPress,
                                        Astro ou sur mesure), avec maintenance
                                        et optimisation continues,</span
                                    >
                                </li>
                                <li class="flex items-start gap-3">
                                    <CheckCircle2
                                        class="w-6 h-6 text-primary-400 shrink-0 mt-0.5"
                                    />
                                    <span
                                        >de l'administration VPS Linux,
                                        l'automatisation de tâches et des
                                        déploiements plus fiables,</span
                                    >
                                </li>
                                <li class="flex items-start gap-3">
                                    <CheckCircle2
                                        class="w-6 h-6 text-primary-400 shrink-0 mt-0.5"
                                    />
                                    <span
                                        >du hardening serveur et des scripts
                                        défensifs sur mesure pour améliorer la
                                        sécurité opérationnelle.</span
                                    >
                                </li>
                            </ul>
                            <p class="pt-6 font-medium text-main">
                                Je suis en transition vers un profil ingénieur
                                systèmes polyvalent. J'évolue vers des systèmes
                                plus bas niveau, l'automatisation avancée et la
                                sécurité infrastructure, avec un apprentissage
                                actif de Rust et Bash.
                            </p>
                        </div>
                    </div>
                    <!-- Tech Icons Section -->
                    <div class="order-1 md:order-2 relative reveal delay-200">
                        <div class="grid grid-cols-2 gap-2">
                            <!-- Linux -->
                            <div class="glass-card flex items-center justify-center aspect-square p-6">
                                <Linux
                                    class="w-24 h-24 md:w-28 md:h-28 text-primary-600"
                                />
                            </div>

                            <!-- Rust -->
                            <div class="glass-card flex items-center justify-center aspect-square p-6">
                                <Rust
                                    class="w-24 h-24 md:w-28 md:h-28 text-primary-600"
                                />
                            </div>

                            <!-- WordPress -->
                            <div class="glass-card flex items-center justify-center aspect-square p-6">
                                <Wordpress
                                    class="w-24 h-24 md:w-28 md:h-28 text-primary-600"
                                />
                            </div>

                            <!-- Bash -->
                            <div class="glass-card flex items-center justify-center aspect-square p-6">
                                <Gnubash
                                    class="w-24 h-24 md:w-28 md:h-28 text-primary-600"
                                />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Section: Philosophie -->
        <section class="py-16 md:py-24">
            <div class="container-custom">
                <div class="max-w-3xl space-y-10 reveal">
                    <h2 class="section-title text-3xl md:text-4xl mb-12">
                        Ma philosophie : simplicité, fiabilité et pragmatisme
                    </h2>
                    <div
                        class="space-y-6 text-lg text-secondary leading-relaxed"
                    >
                        <p>
                            Je privilégie les solutions lisibles et
                            maintenables. Pas de complexité inutile, pas de
                            promesses floues.
                        </p>
                        <p class="text-2xl text-main font-semibold">
                            Une base technique propre, documentée et exploitable.
                        </p>
                        <p>
                            Mon objectif est simple : que votre site tourne
                            correctement dans le temps, avec une infrastructure
                            cohérente et un niveau de sécurité défensive adapté
                            à votre activité.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Section: Ce que j'apporte -->
        <section class="py-16 md:py-24 bg-dark-900/50">
            <div class="container-custom">
                <div class="max-w-5xl">
                    <h2 class="section-title text-3xl md:text-4xl mb-16 reveal">
                        Ce que j’apporte à mes clients
                    </h2>

                    <div class="grid md:grid-cols-2 gap-2 reveal delay-100">
                        <div class="glass-card glass-card--static card-glow p-8 space-y-6">
                            <h3 class="text-xl font-bold text-primary-400">
                                Objectifs
                            </h3>
                            <p class="text-secondary text-lg">
                                Je veux permettre à chacun même sans
                                compétences techniques de :
                            </p>
                            <ul class="space-y-3 mt-2">
                                <li
                                    class="flex items-center gap-2 text-main text-lg"
                                >
                                    <ArrowRight
                                        class="w-4 h-4 text-primary-400"
                                    />
                                    lancer leur projet rapidement,
                                </li>
                                <li
                                    class="flex items-center gap-2 text-main text-lg"
                                >
                                    <ArrowRight
                                        class="w-4 h-4 text-primary-400"
                                    />
                                    développer leur activité,
                                </li>
                                <li
                                    class="flex items-center gap-2 text-main text-lg"
                                >
                                    <ArrowRight
                                        class="w-4 h-4 text-primary-400"
                                    />
                                    faire évoluer une plateforme existante,
                                </li>
                            </ul>
                            <p
                                class="text-base font-medium pt-2 text-secondary"
                            >
                                ...avec un accompagnement clair et humain.
                            </p>
                        </div>

                        <div class="glass-card glass-card--static card-glow p-8 space-y-6">
                            <h3 class="text-xl font-bold text-primary-400">
                                Réalisation
                            </h3>
                            <p class="text-secondary text-lg">
                                J’aime construire des sites, des extensions, des
                                thèmes ou des outils qui répondent vraiment à un
                                besoin, qui tiennent la route techniquement, et
                                que beaucoup ne pourraient pas se permettre
                                auprès d'une agence classique.
                            </p>
                            <p
                                class="font-medium text-main pt-4  -t  -white/5 text-lg"
                            >
                                Mon objectif : vous donner des fondations
                                solides pour créer, vendre et scaler
                                sereinement.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Section: Pour qui je travaille ? -->
        <section class="py-16 md:py-24">
            <div class="container-custom">
                <h2 class="section-title text-3xl md:text-4xl mb-16 reveal">
                    Pour qui je travaille ?
                </h2>
                <div class="grid md:grid-cols-3 gap-2 reveal delay-100">
                    <!-- Card 1 -->
                    <div
                        class="glass-card glass-card--static card-glow p-8 flex flex-col h-full "
                    >
                        <div
                            class="w-14 h-14 rounded-full bg-primary-500/20 flex items-center justify-center mb-6 text-primary-400 font-bold text-2xl"
                        >
                            1
                        </div>
                        <h3 class="text-2xl font-bold mb-4">Solopreneurs</h3>
                        <p class="text-secondary text-lg">
                            Ceux qui veulent se lancer ou automatiser leurs
                            tâches pour gagner du temps et de l'efficacité.
                        </p>
                    </div>
                    <!-- Card 2 -->
                    <div
                        class="glass-card glass-card--static card-glow p-8 flex flex-col h-full "
                    >
                        <div
                            class="w-14 h-14 rounded-full bg-primary-500/20 flex items-center justify-center mb-6 text-primary-400 font-bold text-2xl"
                        >
                            2
                        </div>
                        <h3 class="text-2xl font-bold mb-4">PME</h3>
                        <p class="text-secondary text-lg">
                            Celles qui cherchent un site professionnel, une
                            boutique WordPress performante ou un outil métier
                            sur-mesure.
                        </p>
                    </div>
                    <!-- Card 3 -->
                    <div
                        class="glass-card glass-card--static card-glow p-8 flex flex-col h-full "
                    >
                        <div
                            class="w-14 h-14 rounded-full bg-primary-500/20 flex items-center justify-center mb-6 text-primary-400 font-bold text-2xl"
                        >
                            3
                        </div>
                        <h3 class="text-2xl font-bold mb-4">
                            Entreprises tech
                        </h3>
                        <p class="text-secondary text-lg">
                            Celles qui ont besoin d’un technicien capable de
                            comprendre à la fois le code et l’infrastructure.
                        </p>
                    </div>
                </div>
                <div
                    class="mt-16 text-xl text-secondary reveal delay-200 max-w-3xl"
                >
                    <p>
                        Je travaille à <strong
                            >Perpignan et sa périphérie</strong
                        >, mais j’accompagne aussi mes clients <strong
                            >partout en France à distance</strong
                        >.
                    </p>
                </div>
            </div>
        </section>

        <!-- Section: Collaboration -->
        <section class="py-16 md:py-24 bg-dark-900/50">
            <div class="container-custom">
                <div class="max-w-4xl reveal">
                    <h2 class="section-title text-3xl md:text-4xl mb-12">
                        Une collaboration simple, claire et efficace
                    </h2>
                    <div
                        class="bg-dark-800/50 rounded-2xl p-8 md:p-12    -white/5"
                    >
                        <p class="text-xl mb-8 font-medium text-main">
                            Je m’engage à :
                        </p>
                        <div
                            class="grid md:grid-cols-2 gap-y-6 gap-x-8 text-left max-w-3xl"
                        >
                            <div class="flex items-center gap-4">
                                <CheckCircle2
                                    class="w-6 h-6 text-green-400 flex-shrink-0"
                                />
                                <span class="text-secondary text-lg"
                                    >Comprendre votre besoin réel</span
                                >
                            </div>
                            <div class="flex items-center gap-4">
                                <CheckCircle2
                                    class="w-6 h-6 text-green-400 flex-shrink-0"
                                />
                                <span class="text-secondary text-lg"
                                    >Proposer une solution adaptée</span
                                >
                            </div>
                            <div class="flex items-center gap-4">
                                <CheckCircle2
                                    class="w-6 h-6 text-green-400 flex-shrink-0"
                                />
                                <span class="text-secondary text-lg"
                                    >Projet propre, fiable et évolutif</span
                                >
                            </div>
                            <div class="flex items-center gap-4">
                                <CheckCircle2
                                    class="w-6 h-6 text-green-400 flex-shrink-0"
                                />
                                <span class="text-secondary text-lg"
                                    >Expliquer les choses simplement</span
                                >
                            </div>
                            <div class="flex items-center gap-4 md:col-span-2">
                                <CheckCircle2
                                    class="w-6 h-6 text-green-400 flex-shrink-0"
                                />
                                <span class="text-secondary text-lg"
                                    >Assurer un suivi transparent</span
                                >
                            </div>
                        </div>
                        <p class="mt-10 text-xl text-main leading-relaxed">
                            Mon but est que vous puissiez avancer en confiance,
                            avec un outil qui vous ressemble et qui soutient
                            réellement votre activité.
                        </p>
                        <div class="mt-10">
                            <a
                                href="/contact"
                                class="btn-primary text-lg px-8 py-4"
                            >
                                Travaillons ensemble
                                <ArrowRight class="w-5 h-5" />
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</BaseLayout>

<style>
    .card-glow {
        position: relative;
        overflow: hidden;
    }
    .card-glow::before {
        content: '';
        position: absolute;
        top: var(--glow-y, -100px);
        left: var(--glow-x, -100px);
        width: 250px;
        height: 250px;
        background: radial-gradient(circle, rgba(51, 133, 255, 0.08) 0%, transparent 70%);
        transform: translate(-50%, -50%);
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.3s ease;
        z-index: 0;
    }
    .card-glow:hover::before {
        opacity: 1;
    }
    .card-glow > * {
        position: relative;
        z-index: 1;
    }
</style>

<script>
    document.querySelectorAll('.card-glow').forEach((card) => {
        card.addEventListener('mousemove', (e) => {
            const el = card as HTMLElement;
            const rect = el.getBoundingClientRect();
            const mEvent = e as MouseEvent;
            el.style.setProperty('--glow-x', `${mEvent.clientX - rect.left}px`);
            el.style.setProperty('--glow-y', `${mEvent.clientY - rect.top}px`);
        });
    });
</script>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { Terminal, Server, ShieldCheck, Code, Bot, Globe, CheckCircle2, User, Workflow, LayoutList } from "lucide-astro";

const personSchema = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Elian",
    jobTitle: "Technicien informatique indépendant",
    worksFor: {
        "@id": "https://einformatique.fr/#business",
    },
    address: {
        "@type": "PostalAddress",
        addressLocality: "Rivesaltes",
        postalCode: "66600",
        addressRegion: "Occitanie",
        addressCountry: "FR",
    },
    knowsAbout: [
        "Administration Linux",
        "Docker",
        "Déploiement VPS",
        "Automatisation Python",
        "Sécurité informatique",
        "WordPress",
        "Astro",
    ],
    url: "https://einformatique.fr/about",
};
---

<BaseLayout
    title="A propos | E Informatique"
    description="Qui je suis, ma trajectoire de technicien informatique vers la specialisation infra et DevOps, et la facon dont j'accompagne les TPE/PME."
    jsonLd={personSchema}
>
    <Header />

    <main class="pt-20">
        <!-- En-tête type Hero -->
        <section class="relative py-16 md:py-24 overflow-hidden" aria-labelledby="about-title">
            <div class="absolute inset-0 bg-dark-950"></div>
            <!-- Texture de fond discrète -->
            <div
                class="absolute inset-0 opacity-[0.02]"
                style="background-image: url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNDAiIGhlaWdodD0iNDAiIHZpZXdCb3g9IjAgMCA0MCA0MCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48ZyBmaWxsPSIjZmZmIiBmaWxsLXJ1bGU9ImV2ZW5vZGQiPjxjaXJjbGUgY3g9IjIwIiBjeT0iMjAiIHI9IjEiLz48L2c+PC9zdmc+');"
            ></div>
            <!-- Lueur bleue -->
            <div
                class="absolute top-1/2 left-1/4 -translate-y-1/2 w-96 h-96 bg-primary-500/10 rounded-full blur-[120px] pointer-events-none"
            ></div>

            <div class="container-custom relative z-10">
                <div class="max-w-4xl space-y-8 reveal animate-slide-up">
                    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary-500/10 border border-primary-500/20 text-primary-400 text-sm font-medium mb-2">
                        <User class="w-4 h-4" />
                        <span>Profil</span>
                    </div>
                    <h1
                        id="about-title"
                        class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-main"
                    >
                        A propos
                    </h1>
                    <div class="space-y-5 text-lg text-main/80 max-w-3xl leading-relaxed">
                        <p>
                            Je suis Elian, technicien informatique indépendant à Rivesaltes, près de Perpignan.
                        </p>
                        <p>
                            Je viens du terrain: dépannage, réseaux, postes et sécurité de base pour les TPE/PME.
                        </p>
                        <p>
                            Aujourd'hui, je me spécialise progressivement vers l'infrastructure et le DevOps, avec une approche simple : automatiser ce qui doit l'être, garder le reste lisible.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Parcours / Trajectoire -->
        <section
            class="py-20 md:py-32 bg-dark-900/50"
            aria-labelledby="trajectoire-title"
        >
            <div class="container-custom">
                <div class="max-w-4xl space-y-12 reveal">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-lg bg-primary-600/10 flex items-center justify-center">
                            <Workflow class="w-5 h-5 text-primary-400" />
                        </div>
                        <h2 id="trajectoire-title" class="text-3xl md:text-4xl font-bold">
                            Ma trajectoire
                        </h2>
                    </div>
                    <div class="grid md:grid-cols-3 gap-8 text-secondary">
                        <div class="glass-card glass-card--static p-8 space-y-4">
                            <h3 class="text-xl font-bold text-main">Le terrain</h3>
                            <p>Mon point de départ, c'est le métier de technicien : maintenir des postes, stabiliser des réseaux, gérer les incidents et sécuriser l'essentiel.</p>
                        </div>
                        <div class="glass-card glass-card--static p-8 space-y-4 border-t-2 md:border-t-0 md:border-l-2 border-primary-500/30">
                            <h3 class="text-xl font-bold text-primary-400">L'évolution</h3>
                            <p>L'évolution a été naturelle vers Linux, les VPS et l'automatisation : scripts Python, conteneurs Docker, déploiements propres, supervision et alertes.</p>
                        </div>
                        <div class="glass-card glass-card--static p-8 space-y-4 border-t-2 md:border-t-0 md:border-l-2 border-primary-500/50">
                            <h3 class="text-xl font-bold text-main">La spécialisation</h3>
                            <p>Je ne me présente pas comme un DevOps senior. Je suis en progression active dans cette spécialisation, avec des prestations concrètes déjà opérationnelles pour les entreprises.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Compétences -->
        <section
            class="py-20 md:py-32"
            aria-labelledby="competences-title"
        >
            <div class="container-custom">
                <div class="max-w-4xl space-y-12 reveal">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-lg bg-primary-600/10 flex items-center justify-center">
                            <Code class="w-5 h-5 text-primary-400" />
                        </div>
                        <h2 id="competences-title" class="text-3xl md:text-4xl font-bold">
                            Ce que je sais faire aujourd'hui
                        </h2>
                    </div>
                    <ul class="grid gap-6 md:grid-cols-2 text-secondary" aria-label="Compétences actuelles">
                        <li class="glass-card glass-card--static p-6 md:p-8 flex items-start gap-5">
                            <Terminal class="w-6 h-6 text-primary-400 shrink-0 mt-1" />
                            <div>
                                <strong class="text-main block mb-2">Linux (Debian/Ubuntu)</strong>
                                <span class="leading-relaxed">Administration, hardening, maintenance</span>
                            </div>
                        </li>
                        <li class="glass-card glass-card--static p-6 md:p-8 flex items-start gap-5">
                            <Server class="w-6 h-6 text-primary-400 shrink-0 mt-1" />
                            <div>
                                <strong class="text-main block mb-2">Docker, Nginx & VPS</strong>
                                <span class="leading-relaxed">Déploiements propres sur serveurs distants</span>
                            </div>
                        </li>
                        <li class="glass-card glass-card--static p-6 md:p-8 flex items-start gap-5">
                            <Code class="w-6 h-6 text-primary-400 shrink-0 mt-1" />
                            <div>
                                <strong class="text-main block mb-2">Python</strong>
                                <span class="leading-relaxed">Automatisation, scripts métiers, monitoring</span>
                            </div>
                        </li>
                        <li class="glass-card glass-card--static p-6 md:p-8 flex items-start gap-5">
                            <Bot class="w-6 h-6 text-primary-400 shrink-0 mt-1" />
                            <div>
                                <strong class="text-main block mb-2">Bots automatisés</strong>
                                <span class="leading-relaxed">Telegram pour notifications & alertes directes</span>
                            </div>
                        </li>
                        <li class="glass-card glass-card--static p-6 md:p-8 flex items-start gap-5">
                            <ShieldCheck class="w-6 h-6 text-primary-400 shrink-0 mt-1" />
                            <div>
                                <strong class="text-main block mb-2">Sécurité pratique</strong>
                                <span class="leading-relaxed">Audit de configuration, durcissement, vraies sauvegardes</span>
                            </div>
                        </li>
                        <li class="glass-card glass-card--static p-6 md:p-8 flex items-start gap-5">
                            <Globe class="w-6 h-6 text-primary-400 shrink-0 mt-1" />
                            <div>
                                <strong class="text-main block mb-2">Web (WordPress & Astro)</strong>
                                <span class="leading-relaxed">Sites sécurisés orientés performance avec infra incluse</span>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- Philosophie de travail -->
        <section
            class="py-20 md:py-32 bg-dark-900/50"
            aria-labelledby="methode-title"
        >
            <div class="container-custom">
                <div class="max-w-4xl space-y-12 reveal">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-lg bg-primary-600/10 flex items-center justify-center">
                            <LayoutList class="w-5 h-5 text-primary-400" />
                        </div>
                        <h2 id="methode-title" class="text-3xl md:text-4xl font-bold">
                            Comment je travaille
                        </h2>
                    </div>
                    <div class="glass-card glass-card--static p-8 md:p-12">
                        <ul class="space-y-8 text-secondary text-lg" aria-label="Philosophie de travail">
                            <li class="flex items-start gap-4">
                                <CheckCircle2 class="w-7 h-7 text-green-400 flex-shrink-0 mt-0.5" />
                                <span class="leading-relaxed"><strong class="text-main font-medium">Systèmes autonomes :</strong> le but est que ça tourne sans intervention manuelle quotidienne.</span>
                            </li>
                            <li class="flex items-start gap-4">
                                <CheckCircle2 class="w-7 h-7 text-green-400 flex-shrink-0 mt-0.5" />
                                <span class="leading-relaxed"><strong class="text-main font-medium">Simplicité et efficacité :</strong> je n'ajoute pas de complexité technologique inutile.</span>
                            </li>
                            <li class="flex items-start gap-4">
                                <CheckCircle2 class="w-7 h-7 text-green-400 flex-shrink-0 mt-0.5" />
                                <span class="leading-relaxed"><strong class="text-main font-medium">Un seul interlocuteur :</strong> je maîtrise le code, le serveur et la sécurité.</span>
                            </li>
                            <li class="flex items-start gap-4">
                                <CheckCircle2 class="w-7 h-7 text-green-400 flex-shrink-0 mt-0.5" />
                                <span class="leading-relaxed"><strong class="text-main font-medium">Transparence :</strong> j'explique ce qui est fait et pourquoi, sans jargon gratuit.</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- Pour qui je travaille -->
        <section
            class="py-20 md:py-32 mb-16"
            aria-labelledby="cible-title"
        >
            <div class="container-custom">
                <div class="max-w-4xl space-y-10 reveal">
                    <h2 id="cible-title" class="text-3xl md:text-4xl font-bold">
                        Pour qui je travaille
                    </h2>
                    <div class="p-10 border-l-4 border-primary-500 bg-primary-500/5 rounded-r-2xl">
                        <p class="text-secondary text-lg leading-relaxed mb-6">
                            Principalement pour les <strong class="text-main">TPE/PME des Pyrénées-Orientales</strong> qui n'ont pas de service IT interne et qui veulent un prestataire local, disponible et technique.
                        </p>
                        <p class="text-secondary text-lg leading-relaxed">
                            J'accompagne également des entreprises <strong class="text-main">partout en France à distance</strong> sur les besoins en infrastructure, automatisation et sécurité.
                        </p>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import AnimatedNetworkBg from "../components/AnimatedNetworkBg.astro";
import {
    Terminal,
    Server,
    ShieldCheck,
    Code,
    Bot,
    Globe,
    User,
    MapPin,
    Sparkles,
    ArrowRight,
} from "lucide-astro";

const personSchema = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Elian",
    jobTitle: "Technicien informatique indépendant",
    worksFor: {
        "@id": "https://einformatique.fr/#business",
    },
    address: {
        "@type": "PostalAddress",
        addressLocality: "Rivesaltes",
        postalCode: "66600",
        addressRegion: "Occitanie",
        addressCountry: "FR",
    },
    knowsAbout: [
        "Administration Linux",
        "Docker",
        "Déploiement VPS",
        "Automatisation Python",
        "Sécurité informatique",
        "WordPress",
        "Astro",
        "Déploiement de modèles d'IA",
        "Intelligence artificielle appliquée",
    ],
    url: "https://einformatique.fr/about",
};

const trajectory = [
    {
        step: "Le terrain",
        body: "Mon point de départ, c'est le métier de technicien : maintenir des postes, stabiliser des réseaux, gérer les incidents et sécuriser l'essentiel.",
    },
    {
        step: "L'évolution",
        body: "Une progression naturelle vers Linux, les VPS et l'automatisation : scripts Python, conteneurs Docker, déploiements propres, supervision et alertes.",
    },
    {
        step: "La spécialisation",
        body: "Je ne me présente pas comme un DevOps senior. J'avance pas à pas, avec des prestations concrètes déjà opérationnelles, vers la mise en production de modèles d'IA.",
    },
];

const skills = [
    {
        icon: Terminal,
        title: "Linux (Debian/Ubuntu)",
        desc: "Administration, hardening, maintenance",
    },
    {
        icon: Server,
        title: "Docker, Nginx & VPS",
        desc: "Déploiements propres sur serveurs distants",
    },
    {
        icon: Code,
        title: "Python",
        desc: "Automatisation, scripts métiers, monitoring",
    },
    {
        icon: Bot,
        title: "Bots & IA appliquée",
        desc: "Notifications Telegram et premières intégrations de modèles d'IA",
    },
    {
        icon: ShieldCheck,
        title: "Sécurité pratique",
        desc: "Audit de configuration, durcissement, vraies sauvegardes",
    },
    {
        icon: Globe,
        title: "Web (WordPress & Astro)",
        desc: "Sites sécurisés orientés performance, infra incluse",
    },
];

const method = [
    {
        title: "Systèmes autonomes",
        desc: "Le but : que ça tourne sans intervention manuelle quotidienne.",
    },
    {
        title: "Simplicité et efficacité",
        desc: "Pas de complexité technologique ajoutée sans raison.",
    },
    {
        title: "Un seul interlocuteur",
        desc: "Je maîtrise le code, le serveur et la sécurité.",
    },
    {
        title: "Transparence",
        desc: "J'explique ce qui est fait et pourquoi, sans jargon gratuit.",
    },
];
---

<BaseLayout
    title="À propos | E Informatique"
    description="Qui je suis, ma trajectoire de technicien informatique vers l'infrastructure, le DevOps et la mise en production de l'IA, et la façon dont j'accompagne les TPE/PME."
    jsonLd={personSchema}
>
    <Header />

    <main class="pt-16">
        <!-- ===== HERO ===== -->
        <section
            class="relative pt-16 pb-20 md:pt-24 md:pb-28 overflow-hidden"
            aria-labelledby="about-title"
        >
            <div class="absolute inset-0 grid-texture pointer-events-none"></div>
            <AnimatedNetworkBg />
            <div
                class="absolute -top-32 right-0 w-[30rem] h-[30rem] rounded-full bg-primary-300/15 blur-3xl pointer-events-none"
                aria-hidden="true"
            >
            </div>

            <div class="container-custom relative z-10">
                <div
                    class="grid lg:grid-cols-[1.3fr_0.7fr] gap-12 lg:gap-16 items-center"
                >
                    <!-- Texte -->
                    <div class="reveal">
                        <p class="eyebrow mb-5">Le technicien derrière E Informatique</p>
                        <h1 id="about-title" class="mb-7">
                            Elian, votre informatique
                            <span class="text-highlight">entre de bonnes mains.</span>
                        </h1>
                        <div
                            class="space-y-4 text-lg text-secondary max-w-2xl leading-relaxed"
                        >
                            <p>
                                Technicien informatique indépendant à Rivesaltes,
                                près de Perpignan. Je viens du terrain : dépannage,
                                réseaux, postes et sécurité pour les TPE/PME.
                            </p>
                            <p>
                                Aujourd'hui je me spécialise vers l'infrastructure,
                                le DevOps et, de plus en plus, la mise en production
                                de l'intelligence artificielle. Une approche simple :
                                automatiser ce qui doit l'être, garder le reste lisible.
                            </p>
                        </div>
                        <div class="flex flex-col sm:flex-row gap-3 mt-8">
                            <a href="/contact" class="btn-primary justify-center">
                                <span>Me contacter</span>
                                <ArrowRight class="w-5 h-5" />
                            </a>
                            <a href="/services" class="btn-secondary justify-center">
                                <span>Mes services</span>
                            </a>
                        </div>
                    </div>

                    <!-- Fiche / carte d'identité -->
                    <div class="reveal delay-200">
                        <div class="glass-card p-7 md:p-8">
                            <div class="flex items-center gap-4 mb-6">
                                <div
                                    class="w-16 h-16 rounded-2xl bg-primary-600/10 flex items-center justify-center flex-shrink-0"
                                >
                                    <img
                                        src="/images/logo.svg"
                                        alt="E Informatique"
                                        class="w-9 h-9"
                                    />
                                </div>
                                <div>
                                    <p class="text-xl font-bold text-main leading-tight">
                                        Elian
                                    </p>
                                    <p class="text-secondary text-sm">
                                        Technicien indépendant
                                    </p>
                                </div>
                            </div>
                            <ul class="space-y-4">
                                <li class="flex items-center gap-3">
                                    <MapPin class="w-5 h-5 text-accent-600 flex-shrink-0" />
                                    <span class="text-main text-sm">Rivesaltes · Pyrénées-Orientales (66)</span>
                                </li>
                                <li class="flex items-center gap-3">
                                    <Sparkles class="w-5 h-5 text-primary-600 flex-shrink-0" />
                                    <span class="text-main text-sm">Infra · DevOps · IA appliquée</span>
                                </li>
                                <li class="flex items-center gap-3">
                                    <User class="w-5 h-5 text-primary-600 flex-shrink-0" />
                                    <span class="text-main text-sm">Un seul interlocuteur, du code au serveur</span>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ===== TRAJECTOIRE (timeline) ===== -->
        <section class="py-20 md:py-28 bg-dark-900" aria-labelledby="trajectoire-title">
            <div class="container-custom">
                <div class="max-w-3xl mb-12 reveal">
                    <p class="eyebrow mb-4">Mon parcours</p>
                    <h2 id="trajectoire-title" class="section-title">
                        Du terrain à la mise en production de l'IA
                    </h2>
                </div>

                <ol class="timeline max-w-3xl reveal">
                    {
                        trajectory.map((t, i) => (
                            <li class="timeline-item">
                                <span class="timeline-dot">{String(i + 1)}</span>
                                <div class="pb-10">
                                    <h3 class="text-xl text-main mb-2">{t.step}</h3>
                                    <p class="text-secondary leading-relaxed">{t.body}</p>
                                </div>
                            </li>
                        ))
                    }
                </ol>
            </div>
        </section>

        <!-- ===== COMPÉTENCES ===== -->
        <section class="py-20 md:py-28" aria-labelledby="competences-title">
            <div class="container-custom">
                <div class="max-w-3xl mb-12 reveal">
                    <p class="eyebrow mb-4">Mes compétences</p>
                    <h2 id="competences-title" class="section-title">
                        Ce que je sais faire aujourd'hui
                    </h2>
                </div>
                <ul
                    class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3"
                    aria-label="Compétences actuelles"
                >
                    {
                        skills.map((s, i) => (
                            <li class="glass-card p-6 reveal" style={`transition-delay:${(i % 3) * 80}ms`}>
                                <div
                                    class={`w-11 h-11 rounded-xl flex items-center justify-center mb-4 ${
                                        i % 3 === 1
                                            ? "bg-accent-100"
                                            : "bg-primary-600/10"
                                    }`}
                                >
                                    <s.icon
                                        class={`w-5 h-5 ${i % 3 === 1 ? "text-accent-700" : "text-primary-600"}`}
                                    />
                                </div>
                                <strong class="text-main block mb-1.5">{s.title}</strong>
                                <span class="text-secondary text-sm leading-relaxed">
                                    {s.desc}
                                </span>
                            </li>
                        ))
                    }
                </ul>
            </div>
        </section>

        <!-- ===== MÉTHODE ===== -->
        <section class="py-20 md:py-28 bg-dark-900" aria-labelledby="methode-title">
            <div class="container-custom">
                <div class="grid lg:grid-cols-[0.8fr_1.2fr] gap-12 lg:gap-16">
                    <div class="reveal">
                        <p class="eyebrow mb-4">Ma méthode</p>
                        <h2 id="methode-title" class="section-title mb-4">
                            Comment je travaille
                        </h2>
                        <p class="text-secondary leading-relaxed">
                            Quatre principes simples qui guident chaque
                            intervention, du dépannage ponctuel au projet
                            d'infrastructure complet.
                        </p>
                    </div>
                    <div class="grid sm:grid-cols-2 gap-4 reveal delay-200">
                        {
                            method.map((m, i) => (
                                <div class="glass-card p-6">
                                    <span class="text-sm font-bold tracking-widest text-accent-600 tabular-nums">
                                        {String(i + 1).padStart(2, "0")}
                                    </span>
                                    <h3 class="text-lg text-main mt-2 mb-1.5">{m.title}</h3>
                                    <p class="text-secondary text-sm leading-relaxed">{m.desc}</p>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>
        </section>

        <!-- ===== POUR QUI ===== -->
        <section class="py-20 md:py-28" aria-labelledby="cible-title">
            <div class="container-custom">
                <div class="glass-card p-8 md:p-12 lg:p-16 relative overflow-hidden reveal">
                    <div
                        class="absolute -top-24 -right-24 w-72 h-72 rounded-full bg-primary-300/15 blur-3xl pointer-events-none"
                        aria-hidden="true"
                    >
                    </div>
                    <div class="relative max-w-3xl">
                        <p class="eyebrow mb-4">Pour qui je travaille</p>
                        <h2 id="cible-title" class="section-title mb-6">
                            Des TPE/PME locales, et partout en France à distance
                        </h2>
                        <p class="text-secondary text-lg leading-relaxed mb-4">
                            Principalement pour les
                            <strong class="text-main">TPE/PME des Pyrénées-Orientales</strong>
                            qui n'ont pas de service IT interne et veulent un
                            prestataire local, disponible et technique.
                        </p>
                        <p class="text-secondary text-lg leading-relaxed">
                            J'accompagne aussi des entreprises
                            <strong class="text-main">partout en France à distance</strong>
                            sur l'infrastructure, l'automatisation, la sécurité
                            et l'intelligence artificielle.
                        </p>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</BaseLayout>

<style>
    .timeline {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .timeline-item {
        position: relative;
        padding-left: 3.25rem;
    }

    /* Connector line */
    .timeline-item::before {
        content: "";
        position: absolute;
        left: 1.125rem;
        top: 2.5rem;
        bottom: 0;
        width: 2px;
        background: var(--color-dark-700);
    }

    .timeline-item:last-child::before {
        display: none;
    }

    .timeline-dot {
        position: absolute;
        left: 0;
        top: 0;
        width: 2.375rem;
        height: 2.375rem;
        border-radius: 9999px;
        background: var(--color-primary-600);
        color: var(--color-near-white);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.95rem;
        box-shadow: 0 6px 16px -6px oklch(0.50 0.205 250 / 0.5);
    }
</style>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import ServiceCard from "../components/ServiceCard.astro";
import LocationSection from "../components/LocationSection.astro";
import CTASection from "../components/CTASection.astro";
import Footer from "../components/Footer.astro";
import { Lightbulb, Users } from "lucide-astro";

// Services data - icon names map to Lucide icons in ServiceCard
const services = [
	{
		icon: "monitor",
		title: "Votre site est lent, vieux ou inexistant",
		highlight: "Site web :",
		items: [
			"Création, refonte ou maintenance de votre site",
			"Pages rapides, mises à jour automatiques, sauvegardes incluses",
			"Vous ne vous en occupez plus",
		],
	},
	{
		icon: "server",
		title: "Votre hébergement coûte trop cher ou tombe en panne",
		highlight: "Serveur & hébergement :",
		items: [
			"Configuration de serveurs VPS simples et robustes",
			"Moins cher que les solutions cloud",
			"Plus fiable que l'hébergement mutualisé de base",
		],
	},
	{
		icon: "shield",
		title: "Vous avez peur d'un piratage ou d'une perte de données",
		highlight: "Sécurité :",
		items: [
			"Sécurisation des postes, des serveurs et des accès",
			"Sauvegardes automatiques, audit de configuration",
			"Suppression de malwares",
		],
	},
	{
		icon: "zap",
		title: "Votre ordinateur rame, plante ou se comporte bizarrement",
		highlight: "Dépannage & assistance :",
		items: [
			"Diagnostic, réparation et optimisation de vos machines",
			"Windows, macOS ou Linux",
			"Déplacement à domicile ou en entreprise sur Perpignan et environs",
		],
	},
];
---

<BaseLayout
	title="Elian — Informatique & Web pour les TPE/PME à Perpignan"
	description="Dépannage, site web, serveur, sécurité : un seul interlocuteur pour tous vos problèmes informatiques. Intervention à Perpignan et à distance partout en France."
>
	<Header />

	<main>
		<!-- Hero Section -->
		<Hero />

		<!-- Services Section -->
		<section id="services" class="py-20 md:py-28">
			<div class="container-custom">
				<!-- Section Header -->
				<div class="text-center mb-12 md:mb-16">
					<div
						class="w-14 h-14 rounded-xl bg-primary-600/10 flex items-center justify-center mx-auto mb-4"
					>
						<Lightbulb class="w-7 h-7 text-primary-400" />
					</div>
					<h2 class="section-title text-main">
					Les problèmes que je règle
				</h2>
				<p class="text-secondary max-w-2xl mx-auto">
					Pas de jargon, pas de devis incompréhensible. Vous avez un problème, je le règle.
					</p>
				</div>

				<!-- Services Grid -->
				<div class="grid md:grid-cols-2 lg:grid-cols-6 gap-2">
					{
						services.map((service) => {
							const actualClass = "lg:col-span-3";

							return (
								<ServiceCard
									icon={service.icon}
									title={service.title}
									items={service.items}
									highlight={service.highlight}
									className={actualClass}
								/>
							);
						})
					}
				</div>
			</div>
		</section>

		<!-- Pourquoi travailler avec un seul prestataire Section -->
		<section class="py-20 md:py-28 bg-dark-900/50">
			<div class="container-custom">
				<div class="max-w-3xl mx-auto">
					<div class="flex items-center justify-center mb-4">
						<div class="w-14 h-14 rounded-xl bg-primary-600/10 flex items-center justify-center">
							<Users class="w-7 h-7 text-primary-400" />
						</div>
					</div>
					<h2 class="section-title text-main text-center mb-10">
						Pourquoi travailler avec un seul prestataire ?
					</h2>
					<div class="space-y-6 text-lg text-secondary leading-relaxed">
						<p>
							Quand quelque chose ne fonctionne pas, il faut souvent chercher à la fois du côté du code, du serveur et du réseau. Avoir une seule personne qui connaît ces trois aspects permet de trouver la cause plus vite et d'éviter les allers-retours.
						</p>
						<p>
							Je ne suis pas un généraliste qui fait tout à la fois. Je couvre un périmètre précis : site web, serveur, sécurité et postes de travail. Ce périmètre suffit à répondre à la plupart des besoins d'une petite entreprise.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Location Section -->
		<LocationSection />

		<!-- CTA Section -->
		<CTASection />
	</main>

	<Footer />
</BaseLayout>

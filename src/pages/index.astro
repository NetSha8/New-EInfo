---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import ServiceCard from "../components/ServiceCard.astro";
import LocationSection from "../components/LocationSection.astro";
import CTASection from "../components/CTASection.astro";
import Footer from "../components/Footer.astro";
import { Code2, Server, ShieldCheck } from "lucide-astro";

// Services data - icon names map to Lucide icons in ServiceCard
const services = [
	{
		icon: "settings",
		title: "Votre hébergement est instable ou trop coûteux",
		highlight: "Infrastructure VPS :",
		items: [
			"Serveur Linux configuré proprement pour votre activité",
			"Déploiement fiable de votre site et de vos outils métiers",
			"Supervision 24/7 avec alertes en cas d'incident",
		],
	},
	{
		icon: "bot",
		title: "Vous perdez du temps sur des tâches répétitives",
		highlight: "Automatisation :",
		items: [
			"Scripts Python sur mesure pour automatiser le quotidien",
			"Monitoring et alertes Telegram pour agir rapidement",
			"Veille et contrôles automatiques sans intervention manuelle",
		],
	},
	{
		icon: "shield",
		title: "Vous voulez éviter piratage, perte de données et interruptions",
		highlight: "Sécurité :",
		items: [
			"Durcissement de vos serveurs, postes et accès sensibles",
			"Sauvegardes testées et audit de configuration",
			"Traitement des incidents et remise en état rapide",
		],
	},
	{
		icon: "globe",
		title: "Votre site doit rester rapide et disponible",
		highlight: "Site web :",
		items: [
			"Création ou refonte orientée performance",
			"Maintenance, mises à jour et sauvegardes automatisées",
			"Un site fiable qui sert vraiment votre activité",
		],
	},
	{
		icon: "wrench",
		title: "Votre informatique vous ralentit au quotidien",
		highlight: "Dépannage & assistance :",
		items: [
			"Diagnostic, réparation et optimisation de vos postes",
			"Windows, macOS ou Linux",
			"Déplacement à domicile ou en entreprise sur Perpignan et environs",
		],
	},
];

const homeFaqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	mainEntity: [
		{
			"@type": "Question",
			name: "Intervenez-vous uniquement à Rivesaltes ?",
			acceptedAnswer: {
				"@type": "Answer",
				text: "Non. J'interviens en présentiel à Rivesaltes, Perpignan, Canet-en-Roussillon, Saint-Cyprien et Cabestany, puis à distance partout en France.",
			},
		},
		{
			"@type": "Question",
			name: "Quels services propose E Informatique ?",
			acceptedAnswer: {
				"@type": "Answer",
				text: "Infrastructure VPS, automatisation et monitoring, sécurité informatique, création de site web et dépannage pour TPE/PME.",
			},
		},
		{
			"@type": "Question",
			name: "En combien de temps pouvez-vous intervenir ?",
			acceptedAnswer: {
				"@type": "Answer",
				text: "Selon la situation, une intervention à distance peut commencer le jour même. En présentiel, le délai est généralement sous 48h dans les Pyrénées-Orientales.",
			},
		},
	],
};
---

<BaseLayout
	title="Dépannage Informatique Rivesaltes & PO | E Informatique"
	description="Dépannage informatique, création de site web, sécurité et VPS pour TPE/PME. Intervention à Rivesaltes, Perpignan et dans les Pyrénées-Orientales."
	jsonLd={homeFaqSchema}
>
	<Header />

	<main>
		<!-- Hero Section -->
		<Hero />

		<!-- Services Section -->
		<section id="services" class="py-20 md:py-28">
			<div class="container-custom">
				<!-- Section Header -->
				<div class="max-w-2xl mb-12 md:mb-16">
					<p class="eyebrow mb-4">Ce que je couvre</p>
					<h2 class="section-title text-main">
						Toute la chaîne technique, un seul interlocuteur
					</h2>
					<p class="text-secondary">
						Infrastructure, automatisation, sécurité, site web et dépannage : tout est relié pour que votre système tourne sans vous.
					</p>
				</div>

				<!-- Services Bento -->
				<div class="space-y-4">
					<!-- Featured card -->
					<ServiceCard
						icon={services[0].icon}
						title={services[0].title}
						items={services[0].items}
						highlight={services[0].highlight}
						featured={true}
						index={0}
					/>
					<!-- Remaining cards -->
					<div class="grid md:grid-cols-2 gap-4">
						{
							services.slice(1).map((service, i) => (
								<ServiceCard
									icon={service.icon}
									title={service.title}
									items={service.items}
									highlight={service.highlight}
									index={i + 1}
								/>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<!-- Pourquoi travailler avec un seul prestataire Section -->
		<section class="py-20 md:py-28 bg-dark-900 relative overflow-hidden">
			<div class="container-custom relative z-10">
				<div class="grid lg:grid-cols-[1fr_1fr] gap-12 lg:gap-16 items-center">
					<!-- Text -->
					<div class="reveal">
						<p class="eyebrow mb-4">L'avantage d'un freelance</p>
						<h2 class="section-title text-main mb-6">
							Une seule personne pour le code, le serveur et le réseau
						</h2>
						<div class="space-y-5 text-secondary leading-relaxed">
							<p>
								Quand quelque chose ne fonctionne pas, il faut souvent chercher à la fois du côté du code, du serveur et du réseau. Une seule personne qui maîtrise ces trois aspects trouve la cause plus vite, sans allers-retours entre prestataires.
							</p>
							<p>
								Je ne fais pas tout à la fois : je couvre un périmètre précis (site web, serveur, sécurité, postes de travail) qui suffit à la plupart des besoins d'une petite entreprise.
							</p>
						</div>
					</div>

					<!-- Visual: three connected layers -->
					<div class="reveal delay-200 space-y-3">
						{
							[
								{ icon: Code2, title: "Code & site web", desc: "Création, refonte, maintenance." },
								{ icon: Server, title: "Serveur & infra", desc: "VPS Linux, déploiement, supervision." },
								{ icon: ShieldCheck, title: "Sécurité & réseau", desc: "Durcissement, sauvegardes, incidents." },
							].map((layer) => (
								<div class="glass-card glass-card--static flex items-center gap-4 p-5">
									<div class="w-12 h-12 rounded-xl bg-primary-600/10 flex items-center justify-center flex-shrink-0">
										<layer.icon class="w-6 h-6 text-primary-600" />
									</div>
									<div>
										<h3 class="text-lg text-main mb-0.5">{layer.title}</h3>
										<p class="text-secondary text-sm">{layer.desc}</p>
									</div>
								</div>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<!-- Location Section -->
		<LocationSection />

		<!-- CTA Section -->
		<CTASection />
	</main>

	<Footer />
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { Monitor, Shield, Server, Wrench, CheckCircle2, ArrowRight, Bot } from "lucide-astro";

const title = "Services Informatiques Rivesaltes & Perpignan | TPE/PME";
const description = "Dépannage informatique, création de site web, sécurité et VPS pour TPE/PME. Intervention à Rivesaltes, Perpignan et dans les Pyrénées-Orientales.";

const servicesSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      name: "Infrastructure VPS",
      serviceType: "Hébergement et administration serveur VPS",
      areaServed: ["Rivesaltes", "Perpignan", "Pyrénées-Orientales", "France"],
      provider: { "@id": "https://einformatique.fr/#business" },
      url: "https://einformatique.fr/services#hebergement"
    },
    {
      "@type": "Service",
      name: "Automatisation et monitoring",
      serviceType: "Automatisation technique et surveillance serveurs",
      areaServed: ["Rivesaltes", "Perpignan", "Pyrénées-Orientales", "France"],
      provider: { "@id": "https://einformatique.fr/#business" },
      url: "https://einformatique.fr/services#automatisation-monitoring"
    },
    {
      "@type": "Service",
      name: "Sécurité informatique",
      serviceType: "Audit et sécurisation informatique",
      areaServed: ["Rivesaltes", "Perpignan", "Pyrénées-Orientales", "France"],
      provider: { "@id": "https://einformatique.fr/#business" },
      url: "https://einformatique.fr/services#cybersecurite"
    },
    {
      "@type": "Service",
      name: "Création de site web",
      serviceType: "Création et maintenance de site web",
      areaServed: ["Rivesaltes", "Perpignan", "Pyrénées-Orientales", "France"],
      provider: { "@id": "https://einformatique.fr/#business" },
      url: "https://einformatique.fr/services#sites-web"
    },
    {
      "@type": "Service",
      name: "Dépannage informatique",
      serviceType: "Assistance et dépannage informatique",
      areaServed: ["Rivesaltes", "Perpignan", "Pyrénées-Orientales", "France"],
      provider: { "@id": "https://einformatique.fr/#business" },
      url: "https://einformatique.fr/services#depannage"
    }
  ]
};

const services = [
  {
    id: "hebergement",
    title: "Infrastructure VPS pour TPE/PME",
    icon: Server,
    accroche: "Un serveur Linux propre, stable et surveillé en continu pour héberger votre site et vos outils métiers.",
    content: [
      {
        subtitle: "Une base technique fiable dès le départ",
        text: "Je configure votre VPS de manière lisible et sécurisée : système, accès, pare-feu, sauvegardes et déploiement applicatif. Vous évitez les bricolages qui provoquent des pannes en chaîne."
      },
      {
        subtitle: "Ce que je fais pour vous",
        list: [
          { title: "Préparer un serveur prêt à produire", desc: "Installation Linux, configuration réseau, sécurité d'accès et services essentiels." },
          { title: "Déployer sans interruption", desc: "Déploiement avec procédure de retour arrière pour limiter le risque métier." },
          { title: "Gérer HTTPS, DNS, base et emails", desc: "Tous les éléments techniques alignés pour un fonctionnement stable." },
          { title: "Surveiller l'infrastructure 24/7", desc: "Détection rapide des incidents avant qu'ils bloquent votre activité." }
        ]
      },
      {
        subtitle: "Résultat pour votre entreprise",
        simpleList: [
          "Un coût d'hébergement lisible et maîtrisé",
          "Une infrastructure documentée, facile à faire évoluer",
          "Une continuité de service renforcée",
          "Un seul interlocuteur pour le site, le serveur et la sécurité"
        ]
      }
    ],
    techs: ["Linux", "Docker", "VPS", "HTTPS", "SQL"]
  },
  {
    id: "automatisation-monitoring",
    title: "Automatisation & monitoring",
    icon: Bot,
    accroche: "Vos contrôles techniques tournent automatiquement, avec alertes Telegram quand une action est nécessaire — et, de plus en plus, un coup de main de l'IA pour gagner du temps.",
    content: [
      {
        subtitle: "Automatiser ce qui vous fait perdre du temps",
        text: "Je transforme vos vérifications manuelles en routines fiables : disponibilité serveur, erreurs applicatives, espace disque, expiration de certificats, et autres contrôles adaptés à votre contexte."
      },
      {
        subtitle: "Ce que je fais pour vous",
        list: [
          { title: "Surveillance serveur en continu", desc: "Suivi de la santé système et des services critiques avec seuils clairs." },
          { title: "Alerting Telegram ciblé", desc: "Notification en temps réel uniquement quand une action est utile." },
          { title: "Scripts Python sur mesure", desc: "Automatisation de tâches récurrentes : nettoyage, export, contrôles et relances." },
          { title: "Premiers outils boostés à l'IA", desc: "Petites automatisations s'appuyant sur des modèles d'IA pour le tri, le résumé ou la rédaction." },
          { title: "Initiation aux outils IA", desc: "Prise en main de Claude, ChatGPT et autres assistants pour votre quotidien professionnel." },
          { title: "Scraping de veille légal", desc: "Collecte automatisée d'informations publiques pour votre suivi métier." }
        ]
      },
      {
        subtitle: "Livrables concrets",
        simpleList: [
          "Tableau de bord simple avec les indicateurs utiles",
          "Historique des alertes et incidents",
          "Procédure d'action en cas d'alerte",
          "Maintenance mensuelle possible"
        ]
      }
    ],
    techs: ["Python", "FastAPI", "Monitoring", "Telegram", "IA", "Automatisation"]
  },
  {
    id: "cybersecurite",
    title: "Sécurité informatique pour PME",
    icon: Shield,
    accroche: "Vous n'avez pas besoin d'une usine à gaz, mais d'un niveau de sécurité solide et maintenu dans le temps.",
    content: [
      {
        subtitle: "Sécuriser sans complexifier votre quotidien",
        text: "Je mets en place les protections qui comptent vraiment pour une TPE/PME : accès robustes, sauvegardes restaurables, durcissement des systèmes et procédures en cas d'incident."
      },
      {
        subtitle: "Ce que je fais pour vous",
        list: [
          { title: "Audit des points faibles", desc: "Analyse des postes, serveurs et services exposés avec priorités d'action." },
          { title: "Protection des accès", desc: "2FA, politique de mots de passe et segmentation des droits." },
          { title: "Plan de sauvegarde utile", desc: "Sauvegardes automatiques, tests de restauration et règles de conservation." },
          { title: "Renforcement des serveurs", desc: "Durcissement Linux et réduction de la surface d'attaque." }
        ]
      },
      {
        subtitle: "Ce que vous gagnez",
        simpleList: [
          "Moins de risques de coupure et de rançongiciel",
          "Des accès maîtrisés et traçables",
          "Des données récupérables en cas d'incident",
          "Un cadre sécurité proportionné à votre activité"
        ]
      }
    ],
    techs: ["Audit", "2FA", "Linux", "Sauvegardes", "Hardening"]
  },
  {
    id: "sites-web",
    title: "Site web professionnel et maintenu",
    icon: Monitor,
    accroche: "Un site rapide, sécurisé et entretenu dans la durée pour soutenir votre activité locale.",
    content: [
      {
        subtitle: "Un site utile avant d'être décoratif",
        text: "Votre site doit charger vite, rester disponible et faciliter le contact client. Je conçois ou refonds votre site avec une base technique propre, des sauvegardes automatiques et un suivi continu."
      },
      {
        subtitle: "Ce que je fais pour vous",
        list: [
          { title: "Créer ou refondre votre site", desc: "Structure claire, contenus lisibles et parcours orienté prise de contact." },
          { title: "Optimiser les performances", desc: "Temps de chargement réduit sur mobile et desktop." },
          { title: "Assurer la maintenance", desc: "Mises à jour, sauvegardes, surveillance des erreurs et corrections." },
          { title: "Aligner site et infrastructure", desc: "Configuration serveur, sécurité et emails gérés dans le même périmètre." }
        ]
      },
      {
        subtitle: "Ce que vous obtenez",
        simpleList: [
          "Un site qui reste en ligne et performant",
          "Des contenus faciles à maintenir",
          "Un niveau de sécurité cohérent avec votre activité",
          "Une base prête pour vos évolutions futures"
        ]
      }
    ],
    techs: ["Astro", "WordPress", "Performance", "HTTPS", "Maintenance"]
  },
  {
    id: "depannage",
    title: "Dépannage & assistance informatique",
    icon: Wrench,
    accroche: "Quand ça bloque, j'interviens vite sur Perpignan, les Pyrénées-Orientales et à distance.",
    content: [
      {
        subtitle: "Réparer sans immobiliser votre activité",
        text: "Pannes postes, lenteurs, incidents réseau, messagerie, périphériques : je diagnostique et corrige avec une logique de continuité de travail pour votre équipe."
      },
      {
        subtitle: "Ce que je fais pour vous",
        list: [
          { title: "Diagnostic clair", desc: "Cause identifiée, priorités d'action et estimation avant intervention lourde." },
          { title: "Correction des incidents", desc: "Réparation logicielle et matérielle quand c'est pertinent." },
          { title: "Optimisation des postes", desc: "Nettoyage, réglages et stabilisation des machines." },
          { title: "Support sur site ou à distance", desc: "Intervention adaptée à l'urgence et à la localisation." }
        ]
      },
      {
        subtitle: "Ce qui est inclus",
        simpleList: [
          "Réponse rapide sous 24h ouvrées",
          "Intervention locale dans le 66",
          "Compte rendu simple en fin de mission",
          "Préconisations pour éviter la récidive"
        ]
      }
    ],
    techs: ["Windows", "macOS", "Linux", "Réseau", "Support"]
  }
];
---


<BaseLayout title={title} description={description} jsonLd={servicesSchema}>
  <Header />

  <main class="pt-24 pb-20">
    <!-- Page Header -->
    <section class="container-custom mb-20 md:mb-32 text-left">
      <h1 class="text-4xl md:text-6xl font-bold mb-6 mt-[150px] text-main reveal">
        Des services pensés pour une infrastructure autonome<br />
        <span class="text-highlight">à Perpignan et dans les Pyrénées-Orientales</span>
      </h1>
      <p class="text-xl text-secondary max-w-3xl leading-relaxed reveal delay-100 mb-[150px]">
        Vous n'avez pas de DSI interne, mais votre activité dépend d'outils qui doivent rester disponibles.<br /><br />
        Je couvre site, serveur, sécurité, automatisation et dépannage dans un même périmètre.
      </p>
    </section>

    <!-- Services Content -->
    <div class="flex flex-col gap-64 pb-32">
      {services.map((service, index) => (
        <section id={service.id} class="container-custom scroll-mt-32 ">
          <div class="grid lg:grid-cols-12 gap-10 lg:gap-24 items-start">
            <!-- Sticky Title/Icon Column -->
            <div class={`lg:col-span-5 lg:sticky lg:top-32 h-fit ${index % 2 === 1 ? 'lg:order-last' : ''}`}>
              <div class="glass-card p-6 md:p-8 relative overflow-hidden group">
                <div class="absolute top-0 right-0 -mr-12 -mt-12 p-24 bg-primary-500/10 rounded-full blur-3xl transition-all duration-700"></div>
                
                <div class="w-16 h-16 rounded-2xl bg-primary-600/10 flex items-center justify-center mb-6 text-primary-600">
                  <service.icon class="w-8 h-8" />
                </div>
                
                <h2 class="text-2xl md:text-3xl font-bold mb-4 leading-tight text-main">{service.title}</h2>
                <p class="text-secondary text-base md:text-lg mb-6 leading-relaxed font-light">
                  {service.accroche}
                </p>

                <div class="flex flex-wrap gap-2">
                  {service.techs.map(tech => (
                    <span class="px-3 py-1 rounded-full text-xs font-medium bg-dark-900 text-secondary">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </div>

            <!-- Content Column -->
            <div class="lg:col-span-7 space-y-16 lg:py-4">
              {service.content.map((block) => (
                <div class="reveal">
                  <h3 class="text-2xl md:text-3xl font-bold mb-6 flex items-center gap-4 text-main">
                    <span class="w-12 h-1.5 bg-accent-500 rounded-full flex-shrink-0"></span>
                    {block.subtitle}
                  </h3>
                  
                  {block.text && (
                    <p class="text-secondary text-lg md:text-xl leading-8 mb-8 font-light">
                      {block.text}
                    </p>
                  )}

                  {block.list && (
                    <div class="grid md:grid-cols-2 gap-2 mt-8">
                      {block.list.map((item) => (
                        <div class="glass-card p-8">
                          <h4 class="text-lg font-bold text-main mb-3">{item.title}</h4>
                          <p class="text-secondary text-sm leading-relaxed">{item.desc}</p>
                        </div>
                      ))}
                    </div>
                  )}

                  {block.simpleList && (
                    <ul class="grid sm:grid-cols-2 gap-x-8 gap-y-4 mt-6">
                      {block.simpleList.map((item) => (
                        <li class="flex items-start gap-3 text-secondary text-lg">
                          <CheckCircle2 class="w-6 h-6 text-primary-600 shrink-0 mt-0.5" />
                          <span class="font-light">{item}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              ))}
            </div>
          </div>
        </section>
      ))}
    </div>

    <!-- CTA Section (Footer part of the content) -->
    <section class="container-custom mt-32">
      <div class="glass-card glass-card--static p-12 md:p-16 text-center relative overflow-hidden">
        <div class="absolute inset-0 bg-primary-600/5"></div>
        <div class="absolute -top-24 -right-24 w-96 h-96 bg-primary-500/20 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-primary-500/20 rounded-full blur-3xl"></div>
        
        <div class="relative z-10 max-w-2xl mx-auto">
          <h2 class="text-3xl md:text-4xl font-bold mb-6">Pas sûr de quel service vous avez besoin ?</h2>
          <p class="text-xl text-secondary mb-10">
            Décrivez-moi votre situation en deux lignes. Je vous dis exactement ce que je peux faire pour vous, sans engagement.
          </p>
          
          <div class="flex flex-col md:flex-row items-center justify-center gap-6">
            <a href="/contact/" class="btn-primary text-lg px-8 py-4">
              Me décrire mon problème
              <ArrowRight class="w-5 h-5" />
            </a>
          </div>

          <div class="mt-12 pt-8 border-t border-dark-700/50 flex flex-col md:flex-row items-center justify-center gap-4 text-sm text-secondary">
            <span class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-green-500"></div>
              Perpignan & périphérie
            </span>
            <span class="hidden md:block">•</span>
            <span class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-blue-500"></div>
              À distance partout en France
            </span>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

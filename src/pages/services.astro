---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { Monitor, Shield, Server, Wrench, CheckCircle2, ArrowRight } from "lucide-astro";

const title = "Services Informatiques Rivesaltes & Perpignan | TPE/PME";
const description = "Dépannage informatique, création de site web, sécurité et VPS pour TPE/PME. Intervention à Rivesaltes, Perpignan et dans les Pyrénées-Orientales.";

const servicesSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      name: "Dépannage informatique",
      serviceType: "Assistance et dépannage informatique",
      areaServed: ["Rivesaltes", "Perpignan", "Pyrénées-Orientales", "France"],
      provider: { "@id": "https://einformatique.fr/#business" },
      url: "https://einformatique.fr/services#depannage"
    },
    {
      "@type": "Service",
      name: "Création de site web",
      serviceType: "Création et maintenance de site web",
      areaServed: ["Rivesaltes", "Perpignan", "Pyrénées-Orientales", "France"],
      provider: { "@id": "https://einformatique.fr/#business" },
      url: "https://einformatique.fr/services#sites-web"
    },
    {
      "@type": "Service",
      name: "Sécurité informatique",
      serviceType: "Audit et sécurisation informatique",
      areaServed: ["Rivesaltes", "Perpignan", "Pyrénées-Orientales", "France"],
      provider: { "@id": "https://einformatique.fr/#business" },
      url: "https://einformatique.fr/services#cybersecurite"
    },
    {
      "@type": "Service",
      name: "Hébergement VPS",
      serviceType: "Hébergement et administration serveur VPS",
      areaServed: ["Rivesaltes", "Perpignan", "Pyrénées-Orientales", "France"],
      provider: { "@id": "https://einformatique.fr/#business" },
      url: "https://einformatique.fr/services#hebergement"
    }
  ]
};

const services = [
  {
    id: "depannage",
    title: "Dépannage & assistance informatique",
    icon: Wrench,
    accroche: "Votre machine plante, ralentit ou se comporte bizarrement ? Je viens ou je me connecte à distance.",
    content: [
      {
        subtitle: "Pas besoin d'attendre une semaine",
        text: "Pas besoin d'attendre une semaine qu'un technicien se libère. Je me déplace à Perpignan et dans les Pyrénées-Orientales, ou j'interviens à distance en quelques minutes si la situation le permet."
      },
      {
        subtitle: "Ce que je fais pour vous",
        list: [
          { title: "Identifier et corriger la panne", desc: "Diagnostic complet et résolution du problème, sans jargon inutile." },
          { title: "Protéger votre machine des virus et intrusions", desc: "Détection et suppression de malwares, mise en place de protections efficaces." },
          { title: "Rendre votre machine rapide à nouveau", desc: "Nettoyage, optimisation et réglages pour retrouver les performances d'origine." },
          { title: "Faire fonctionner box, Wi-Fi et imprimantes ensemble", desc: "Configuration réseau, partage d'imprimante, connexion des appareils." }
        ]
      },
      {
        subtitle: "Ce qui est inclus",
        simpleList: [
          "Intervention sous 48h sur Perpignan",
          "Diagnostic clair avant toute intervention",
          "Déplacement à domicile ou en entreprise",
          "Intervention à distance disponible en quelques minutes"
        ]
      }
    ],
    techs: ["Windows", "macOS", "Linux", "Réseaux", "Sécurité postes"]
  },
  {
    id: "sites-web",
    title: "Création et maintenance de site web",
    icon: Monitor,
    accroche: "Un site qui charge en moins d'une seconde, sécurisé, mis à jour automatiquement. Vous n'y pensez plus.",
    content: [
      {
        subtitle: "Un site non maintenu, c'est un site vulnérable",
        text: "Un site WordPress non maintenu se fait pirater. Un site lent perd des visiteurs avant même qu'ils lisent une ligne. Je m'occupe des mises à jour, des sauvegardes et des optimisations. Vous gardez le résultat sans avoir à vous en préoccuper."
      },
      {
        subtitle: "Ce que je fais pour vous",
        list: [
          { title: "Votre site toujours à jour et sauvegardé", desc: "Mises à jour régulières, sauvegardes automatiques, surveillance des composants critiques." },
          { title: "Un site qui charge vite sur mobile comme sur desktop", desc: "Optimisation des images, du code et du cache pour un chargement rapide." },
          { title: "Donner un second souffle à un site vieillissant", desc: "Refonte visuelle et technique pour redonner de la valeur à un site existant." },
          { title: "Créer votre site de zéro, adapté à votre activité", desc: "WordPress pour une gestion simple, Astro pour la performance maximale." }
        ]
      },
      {
        subtitle: "Mes garanties qualité",
        simpleList: [
          "Chargement rapide sur mobile et desktop",
          "WordPress (facile à gérer vous-même après livraison)",
          "Sauvegardes quotidiennes automatiques",
          "Sécurité de base incluse (HTTPS, protection contre les attaques courantes)",
          "Un seul interlocuteur pour le site, le serveur et les emails"
        ]
      }
    ],
    techs: ["WordPress (gestion simple)", "Astro (performance maximale)", "HTTPS", "Sauvegardes auto"]
  },
  {
    id: "cybersecurite",
    title: "Sécurité informatique pour PME",
    icon: Shield,
    accroche: "Vous n'êtes pas une grande entreprise, mais vous êtes quand même une cible. Voici comment se protéger sans se ruiner.",
    content: [
      {
        subtitle: "80\u00a0% des cyberattaques visent les petites structures",
        text: "80\u00a0% des cyberattaques visent les petites structures, justement parce qu'elles ne sont pas protégées. Pas besoin d'un budget sécurité de grand groupe\u00a0: des mesures simples et bien faites suffisent pour éliminer 90\u00a0% des risques courants."
      },
      {
        subtitle: "Ce que je fais pour vous",
        list: [
          { title: "Trouver vos failles avant que quelqu'un d'autre le fasse", desc: "Audit de sécurité de vos systèmes, serveurs et sites avec recommandations concrètes." },
          { title: "Bloquer les accès non autorisés à vos comptes", desc: "Mise en place de la double authentification (2FA) sur vos outils critiques." },
          { title: "Ne plus jamais utiliser \"123456\" ou un post-it", desc: "Déploiement et formation à un gestionnaire de mots de passe adapté à votre équipe." },
          { title: "Scripts sur mesure pour surveiller vos systèmes automatiquement", desc: "Outils automatisés pour détecter les anomalies et vous alerter avant qu'un problème devienne grave." }
        ]
      },
      {
        subtitle: "Ce que vous gagnez",
        simpleList: [
          "Moins de risques de piratage ou de rançongiciel",
          "Vos données sauvegardées et récupérables",
          "Vos comptes protégés contre les intrusions",
          "Un niveau de sécurité adapté à votre taille"
        ]
      }
    ],
    techs: ["Audit sécurité", "2FA", "Gestionnaire de mots de passe", "Backup", "Hardening"]
  },
  {
    id: "hebergement",
    title: "Hébergement & serveur pour votre activité",
    icon: Server,
    accroche: "Votre hébergement coûte trop cher ou tombe en panne ? Un VPS Linux bien configuré règle souvent les deux problèmes.",
    content: [
      {
        subtitle: "Des offres trop chères ou trop complexes",
        text: "OVH, AWS, Infomaniak... Les offres d'hébergement sont soit trop chères, soit trop complexes pour ce dont vous avez besoin. Je configure un VPS Linux propre, sécurisé et performant, pour un coût bien inférieur à une solution cloud standard."
      },
      {
        subtitle: "Ce que je fais pour vous",
        list: [
          { title: "Un serveur sécurisé prêt à l'emploi", desc: "Configuration complète d'un VPS Linux : système, sécurité, pare-feu et accès." },
          { title: "Vos applications déployées sans interruption de service", desc: "Déploiement fiable avec retour arrière possible en cas de problème." },
          { title: "Tout configuré : domaine, HTTPS, base de données, emails", desc: "Une infrastructure complète et fonctionnelle, sans pièces manquantes." },
          { title: "Surveillance automatique et alertes en cas de problème", desc: "Monitoring de vos services avec notification immédiate en cas d'incident." }
        ]
      },
      {
        subtitle: "Résultat pour vous",
        simpleList: [
          "Un hébergement fiable, à coût prévisible",
          "Moins cher que les solutions cloud, plus fiable que l'hébergement mutualisé",
          "Un serveur que vous comprenez et contrôlez",
          "Un seul interlocuteur pour le site, le serveur et les emails"
        ]
      }
    ],
    techs: ["VPS Linux", "HTTPS & DNS", "Docker (déploiement fiable)", "Monitoring", "Emails professionnels"]
  }
];
---


<BaseLayout title={title} description={description} jsonLd={servicesSchema}>
  <Header />

  <main class="pt-24 pb-20">
    <!-- Page Header -->
    <section class="container-custom mb-20 md:mb-32 text-center">
      <h1 class="text-4xl md:text-6xl font-bold mb-6 mt-[150px] text-main reveal">
        Ce que je règle<br />
        <span class="text-highlight">pour votre entreprise</span>
      </h1>
      <p class="text-xl text-secondary max-w-3xl mx-auto leading-relaxed reveal delay-100 mb-[150px]">
        Vous n'avez pas de service informatique interne. Vous n'avez pas envie d'apprendre à gérer un serveur. Vous voulez juste que ça fonctionne.<br /><br />
        C'est exactement ce que je fais.
      </p>
    </section>

    <!-- Services Content -->
    <div class="flex flex-col gap-64 pb-32">
      {services.map((service, index) => (
        <section id={service.id} class="container-custom scroll-mt-32 ">
          <div class="grid lg:grid-cols-12 gap-10 lg:gap-24 items-start">
            <!-- Sticky Title/Icon Column -->
            <div class={`lg:col-span-5 lg:sticky lg:top-32 h-fit ${index % 2 === 1 ? 'lg:order-last' : ''}`}>
              <div class="glass-card p-6 md:p-8 relative overflow-hidden group    -white/5  -xl  -black/20">
                <div class="absolute top-0 right-0 -mr-12 -mt-12 p-24 bg-primary-500/10 rounded-full blur-3xl transition-all duration-700"></div>
                
                <div class="w-16 h-16 rounded-2xl bg-primary-600/10 flex items-center justify-center mb-6 text-primary-400    -primary-500/20">
                  <service.icon class="w-8 h-8" />
                </div>
                
                <h2 class="text-2xl md:text-3xl font-bold mb-4 leading-tight text-main">{service.title}</h2>
                <p class="text-secondary text-base md:text-lg mb-6 leading-relaxed font-light">
                  {service.accroche}
                </p>

                <div class="flex flex-wrap gap-2">
                  {service.techs.map(tech => (
                    <span class="px-3 py-1 rounded-full text-xs font-medium bg-dark-800/80 text-secondary    -dark-600/50 transition-colors">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </div>

            <!-- Content Column -->
            <div class="lg:col-span-7 space-y-16 lg:py-4">
              {service.content.map((block) => (
                <div class="reveal">
                  <h3 class="text-2xl md:text-3xl font-bold mb-6 flex items-center gap-4 text-main">
                    <span class="w-12 h-1.5 bg-primary-500 rounded-full  -[0_0_10px_rgba(59,130,246,0.5)]"></span>
                    {block.subtitle}
                  </h3>
                  
                  {block.text && (
                    <p class="text-secondary text-lg md:text-xl leading-8 mb-8 font-light">
                      {block.text}
                    </p>
                  )}

                  {block.list && (
                    <div class="grid md:grid-cols-2 gap-2 mt-8">
                      {block.list.map((item) => (
                        <div class="surface-elevated p-8 rounded-2xl    -dark-700/50 transition-all duration-300">
                          <h4 class="text-lg font-bold text-main mb-3">{item.title}</h4>
                          <p class="text-secondary text-sm leading-relaxed">{item.desc}</p>
                        </div>
                      ))}
                    </div>
                  )}

                  {block.simpleList && (
                    <ul class="grid sm:grid-cols-2 gap-x-8 gap-y-4 mt-6">
                      {block.simpleList.map((item) => (
                        <li class="flex items-start gap-3 text-secondary text-lg">
                          <CheckCircle2 class="w-6 h-6 text-primary-400 shrink-0 mt-0.5" />
                          <span class="font-light">{item}</span>
                        </li>
                      ))}
                    </ul>
                  )}

                  <div class="mt-6 text-sm text-secondary flex flex-wrap gap-3">
                    <span class="text-main">Services liés :</span>
                    {service.id !== "depannage" && <a href="/services#depannage" class="hover:text-primary-400 transition-colors">dépannage informatique</a>}
                    {service.id !== "sites-web" && <a href="/services#sites-web" class="hover:text-primary-400 transition-colors">création de site web</a>}
                    {service.id !== "cybersecurite" && <a href="/services#cybersecurite" class="hover:text-primary-400 transition-colors">sécurité informatique</a>}
                    {service.id !== "hebergement" && <a href="/services#hebergement" class="hover:text-primary-400 transition-colors">hébergement VPS</a>}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>
      ))}
    </div>

    <!-- CTA Section (Footer part of the content) -->
    <section class="container-custom mt-32">
      <div class="glass-card glass-card--static p-12 md:p-16 text-center relative overflow-hidden">
        <div class="absolute inset-0 bg-primary-600/5"></div>
        <div class="absolute -top-24 -right-24 w-96 h-96 bg-primary-500/20 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-primary-500/20 rounded-full blur-3xl"></div>
        
        <div class="relative z-10 max-w-2xl mx-auto">
          <h2 class="text-3xl md:text-4xl font-bold mb-6">Pas sûr de quel service vous avez besoin ?</h2>
          <p class="text-xl text-secondary mb-10">
            Décrivez-moi votre situation en deux lignes. Je vous dis exactement ce que je peux faire pour vous, sans engagement.
          </p>
          
          <div class="flex flex-col md:flex-row items-center justify-center gap-6">
            <a href="/contact" class="btn-primary text-lg px-8 py-4">
              Me décrire mon problème
              <ArrowRight class="w-5 h-5" />
            </a>
          </div>

          <div class="mt-12 pt-8  -t  -dark-700/50 flex flex-col md:flex-row items-center justify-center gap-4 text-sm text-secondary">
            <span class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-green-500"></div>
              Perpignan & périphérie
            </span>
            <span class="hidden md:block">•</span>
            <span class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-blue-500"></div>
              À distance partout en France
            </span>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { Monitor, Shield, Zap, Server, CheckCircle2, ArrowRight } from "lucide-astro";

const title = "Services web, infrastructure & sécurité | E Informatique";
const description = "Services orientés production : sites web et WordPress, infrastructure Linux VPS, automatisation, cybersécurité défensive et optimisation des performances.";

const services = [
  {
    id: "sites-web",
    title: "Sites web & WordPress",
    icon: Monitor,
    accroche: "Création, maintenance et optimisation de sites web orientés fiabilité, performance et évolutivité.",
    content: [
      {
        subtitle: "Un site qui tient dans le temps",
        text: "Je conçois des sites web qui restent rapides, stables et maintenables. L'objectif n'est pas seulement de livrer un site, mais de garder une base propre que vous pouvez faire évoluer sans blocage technique."
      },
      {
        subtitle: "Ce que je fais pour vous",
        list: [
          { title: "Création WordPress, Astro ou sur mesure", desc: "Site vitrine, site administrable ou base custom selon vos besoins métier." },
          { title: "Maintenance corrective et évolutive", desc: "Mises à jour, correction de bugs, suivi des composants critiques." },
          { title: "Optimisation vitesse et Core Web Vitals", desc: "Travail sur le front, les assets, le cache et l'infrastructure web." },
          { title: "Sécurité et sauvegardes", desc: "Mise en place de sauvegardes et mesures défensives de base." }
        ]
      },
      {
        subtitle: "Résultat attendu",
        simpleList: [
          "Un site plus fiable en production",
          "Des temps de chargement plus courts",
          "Une maintenance claire et planifiable",
          "Moins d'incidents liés aux mises à jour"
        ]
      }
    ],
    techs: ["WordPress", "Astro", "TypeScript", "PHP", "Performance"]
  },
  {
    id: "platform",
    title: "Platform Engineering & Infrastructure VPS",
    icon: Server,
    accroche: "Je mets en place une base technique propre pour héberger, déployer et exploiter vos applications web sans complexité inutile.",
    content: [
      {
        subtitle: "Le différenciateur technique",
        text: "Un site web ne vaut que par son exploitation réelle. J'interviens sur l'infrastructure Linux et les processus de déploiement pour éviter les mises en prod fragiles, les environnements incohérents et les incidents répétitifs."
      },
      {
        subtitle: "Ce que je mets en place",
        list: [
          { title: "VPS Linux Debian/Ubuntu", desc: "Configuration initiale, base système propre et sécurisée." },
          { title: "Déploiement Docker et Kamal", desc: "Livraisons plus fiables et rollback simplifié." },
          { title: "Nginx, HTTPS, DNS", desc: "Configuration web serveur, certificats et routage." },
          { title: "CI/CD GitHub Actions", desc: "Automatisation des tâches répétitives et déploiements contrôlés." }
        ]
      },
      {
        subtitle: "Bénéfices concrets",
        simpleList: [
          "Mises en production plus prévisibles",
          "Infrastructure lisible et maintenable",
          "Moins de dépendance aux manipulations manuelles",
          "Coûts maîtrisés sur VPS"
        ]
      }
    ],
    techs: ["Linux", "Docker", "Kamal", "Nginx", "GitHub Actions", "VPS"]
  },
  {
    id: "cybersecurite",
    title: "Cybersécurité & Hardening serveur",
    icon: Shield,
    accroche: "Sécurité défensive pragmatique pour PME : réduire la surface d'attaque et sécuriser l'exploitation de vos services.",
    content: [
      {
        subtitle: "Approche défensive orientée terrain",
        text: "Je travaille sur les points qui réduisent vraiment le risque : configuration serveur, exposition réseau, droits, services actifs et scripts de contrôle. L'objectif est d'améliorer rapidement votre posture de sécurité sans alourdir votre fonctionnement."
      },
      {
        subtitle: "Services proposés",
        list: [
          { title: "Hardening de serveurs Linux", desc: "Renforcement des configurations système et réseau." },
          { title: "Audit de configuration VPS", desc: "Revue technique avec recommandations priorisées et actionnables." },
          { title: "Scripts défensifs sur mesure", desc: "Outils automatisés pour contrôles, alertes et vérifications régulières." },
          { title: "Réponse à incident basique PME", desc: "Première analyse, confinement initial et plan de remédiation court terme." }
        ]
      },
      {
        subtitle: "Ce que vous gagnez",
        simpleList: [
          "Moins de failles de configuration",
          "Une meilleure hygiène de sécurité opérationnelle",
          "Des contrôles récurrents automatisés",
          "Une réaction plus rapide en cas d'incident"
        ]
      }
    ],
    techs: ["Linux", "Hardening", "Audit VPS", "Scripts Bash", "Sécurité défensive"]
  },
  {
    id: "performance",
    title: "Performance & Optimisation",
    icon: Zap,
    accroche: "J'optimise la performance applicative et système pour améliorer vitesse, stabilité et coût d'exploitation.",
    content: [
      {
        subtitle: "Performance utile",
        text: "L'optimisation ne se limite pas à un score. Je travaille sur les éléments qui impactent réellement l'expérience utilisateur, la stabilité en charge et la consommation de ressources côté serveur."
      },
      {
        subtitle: "Axes d'optimisation",
        list: [
          { title: "Front-end et rendu", desc: "Poids des pages, chargement des assets, parcours critique." },
          { title: "Back-end et traitement", desc: "Réduction des temps de réponse et simplification des traitements." },
          { title: "Nginx, cache, compression", desc: "Réglages serveur pour gagner en rapidité et robustesse." },
          { title: "Suivi de métriques", desc: "Mesure continue pour piloter les améliorations." }
        ]
      },
      {
        subtitle: "Résultats visés",
        simpleList: [
          "Temps de chargement réduits",
          "Meilleurs Core Web Vitals",
          "Infrastructure plus stable",
          "Coût serveur mieux maîtrisé"
        ]
      }
    ],
    techs: ["Core Web Vitals", "Nginx", "Cache", "Monitoring", "Optimisation"]
  }
];
---

<BaseLayout title={title} description={description}>
  <Header />

  <main class="pt-24 pb-20">
    <!-- Page Header -->
    <section class="container-custom mb-20 md:mb-32 text-center">
      <h1 class="text-4xl md:text-6xl font-bold mb-6 mt-[150px] text-main reveal">
        Services web, infrastructure <br />
        <span class="text-highlight">& sécurité défensive</span>
      </h1>
      <p class="text-xl text-secondary max-w-3xl mx-auto leading-relaxed reveal delay-100 mb-[150px]">
        J'interviens sur le site et sur le système qui le fait tourner : développement web, WordPress, VPS Linux, automatisation et hardening. Objectif : une base technique fiable, maintenable et performante.
      </p>
    </section>

    <!-- Services Content -->
    <div class="flex flex-col gap-64 pb-32">
      {services.map((service, index) => (
        <section id={service.id} class="container-custom scroll-mt-32 ">
          <div class="grid lg:grid-cols-12 gap-10 lg:gap-24 items-start">
            <!-- Sticky Title/Icon Column -->
            <div class={`lg:col-span-5 lg:sticky lg:top-32 h-fit ${index % 2 === 1 ? 'lg:order-last' : ''}`}>
              <div class="glass-card p-6 md:p-8 relative overflow-hidden group    -white/5  -xl  -black/20">
                <div class="absolute top-0 right-0 -mr-12 -mt-12 p-24 bg-primary-500/10 rounded-full blur-3xl transition-all duration-700"></div>
                
                <div class="w-16 h-16 rounded-2xl bg-primary-600/10 flex items-center justify-center mb-6 text-primary-400    -primary-500/20">
                  <service.icon class="w-8 h-8" />
                </div>
                
                <h2 class="text-2xl md:text-3xl font-bold mb-4 leading-tight text-main">{service.title}</h2>
                <p class="text-secondary text-base md:text-lg mb-6 leading-relaxed font-light">
                  {service.accroche}
                </p>

                <div class="flex flex-wrap gap-2">
                  {service.techs.map(tech => (
                    <span class="px-3 py-1 rounded-full text-xs font-medium bg-dark-800/80 text-secondary    -dark-600/50 transition-colors">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </div>

            <!-- Content Column -->
            <div class="lg:col-span-7 space-y-16 lg:py-4">
              {service.content.map((block) => (
                <div class="reveal">
                  <h3 class="text-2xl md:text-3xl font-bold mb-6 flex items-center gap-4 text-main">
                    <span class="w-12 h-1.5 bg-primary-500 rounded-full  -[0_0_10px_rgba(59,130,246,0.5)]"></span>
                    {block.subtitle}
                  </h3>
                  
                  {block.text && (
                    <p class="text-secondary text-lg md:text-xl leading-8 mb-8 font-light">
                      {block.text}
                    </p>
                  )}

                  {block.list && (
                    <div class="grid md:grid-cols-2 gap-2 mt-8">
                      {block.list.map((item) => (
                        <div class="surface-elevated p-8 rounded-2xl    -dark-700/50 transition-all duration-300">
                          <h4 class="text-lg font-bold text-main mb-3">{item.title}</h4>
                          <p class="text-secondary text-sm leading-relaxed">{item.desc}</p>
                        </div>
                      ))}
                    </div>
                  )}

                  {block.simpleList && (
                    <ul class="grid sm:grid-cols-2 gap-x-8 gap-y-4 mt-6">
                      {block.simpleList.map((item) => (
                        <li class="flex items-start gap-3 text-secondary text-lg">
                          <CheckCircle2 class="w-6 h-6 text-primary-400 shrink-0 mt-0.5" />
                          <span class="font-light">{item}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              ))}
            </div>
          </div>
        </section>
      ))}
    </div>

    <!-- CTA Section (Footer part of the content) -->
    <section class="container-custom mt-32">
      <div class="glass-card glass-card--static p-12 md:p-16 text-center relative overflow-hidden">
        <div class="absolute inset-0 bg-primary-600/5"></div>
        <div class="absolute -top-24 -right-24 w-96 h-96 bg-primary-500/20 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-primary-500/20 rounded-full blur-3xl"></div>
        
        <div class="relative z-10 max-w-2xl mx-auto">
          <h2 class="text-3xl md:text-4xl font-bold mb-6">Prêt à démarrer votre projet ?</h2>
          <p class="text-xl text-secondary mb-10">
            Discutons de vos besoins et trouvons ensemble la solution la plus adaptée à votre activité.
          </p>
          
          <div class="flex flex-col md:flex-row items-center justify-center gap-6">
            <a href="/contact" class="btn-primary text-lg px-8 py-4">
              Demander un devis
              <ArrowRight class="w-5 h-5" />
            </a>
          </div>

          <div class="mt-12 pt-8  -t  -dark-700/50 flex flex-col md:flex-row items-center justify-center gap-4 text-sm text-secondary">
            <span class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-green-500"></div>
              Perpignan & périphérie
            </span>
            <span class="hidden md:block">•</span>
            <span class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-blue-500"></div>
              À distance partout en France
            </span>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

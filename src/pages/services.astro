---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { Monitor, ShoppingBag, Shield, Zap, Server, CheckCircle2, ArrowRight, Bot, Wrench } from "lucide-astro";

const title = "Services de Développement Web | Développeur Freelance Perpignan";
const description = "Services de développement web sur mesure : sites modernes, e-commerce WordPress, web apps, automatisation et platform engineering. Intervention Perpignan et à distance partout en France.";

const services = [
  {
    id: "sites-web",
    title: "Sites web, maintenance & optimisation WordPress",
    icon: Monitor,
    accroche: "Création, maintenance et optimisation de sites WordPress et sur mesure. Un site rapide, sécurisé et régulièrement mis à jour pour des résultats durables.",
    content: [
      {
        subtitle: "Pourquoi investir dans la maintenance de votre site ?",
        text: "Un site web non maintenu devient vulnérable, lent et pénalisé par Google. Mises à jour WordPress, optimisation des performances, vérifications de sécurité, sauvegardes régulières… Je prends en charge tout le cycle de vie de votre site pour que vous puissiez vous concentrer sur votre activité."
      },
      {
        subtitle: "Ce que je fais pour vous",
        list: [
          { title: "Maintenance WordPress complète", desc: "Mises à jour de WordPress, thèmes et plugins, surveillance et corrections." },
          { title: "Optimisation des performances", desc: "Accélération du chargement, cache, compression d'images, score PageSpeed." },
          { title: "Refonte et modernisation", desc: "Remise à niveau de sites vieillissants : performances, sécurité et stabilité." },
          { title: "Création WordPress / Astro / sur mesure", desc: "Sites administrables ou développement custom selon vos besoins." }
        ]
      },
      {
        subtitle: "Mes garanties qualité",
        simpleList: [
          "Mises à jour régulières et sauvegardes automatiques",
          "Vitesse de chargement optimisée en continu",
          "Structure technique propre (balises, Core Web Vitals)",
          "Sécurisation : HTTPS, pare-feu, monitoring",
          "Code propre et maintenable",
          "Rapport mensuel de suivi"
        ]
      }
    ],
    techs: ["WordPress", "Astro", "Performance", "Maintenance", "Sécurité"]
  },
  {
    id: "maintenance-particuliers",
    title: "Maintenance & assistance systèmes (particuliers)",
    icon: Wrench,
    accroche: "Dépannage, sécurisation et fiabilisation de vos équipements informatiques. Un accompagnement humain et accessible pour votre quotidien numérique.",
    content: [
      {
        subtitle: "Un accompagnement informatique de proximité",
        text: "Vous rencontrez des lenteurs, des pannes ou des comportements suspects sur votre ordinateur ? Je vous accompagne pour diagnostiquer, réparer et sécuriser vos équipements. Mon approche : des explications claires, des solutions durables, et une vraie pédagogie pour que vous compreniez ce qui se passe."
      },
      {
        subtitle: "Services proposés",
        list: [
          { title: "Dépannage et diagnostic", desc: "Identification et résolution des problèmes matériels et logiciels." },
          { title: "Sécurisation des postes", desc: "Antivirus, pare-feu, mises à jour, suppression de malwares." },
          { title: "Optimisation et nettoyage", desc: "Accélération des machines lentes, suppression des bloatwares." },
          { title: "Configuration réseau", desc: "Box internet, Wi-Fi, imprimantes, NAS, partage réseau." }
        ]
      },
      {
        subtitle: "Ce qui est inclus",
        simpleList: [
          "Déplacement à domicile (Perpignan et environs)",
          "Assistance à distance quand c'est possible",
          "Sauvegardes et récupération de données",
          "Conseils d'achat de matériel",
          "Formation de base incluse",
          "Suivi post-intervention"
        ]
      }
    ],
    techs: ["Windows", "macOS", "Linux", "Réseaux", "Sécurité poste", "Sauvegardes"]
  },
  {
    id: "cybersecurite",
    title: "Cybersécurité & Protection numérique",
    icon: Shield,
    accroche: "Protégez votre vie numérique et celle de votre entreprise. Je vous accompagne pour sécuriser vos données, vos accès et vos systèmes contre les menaces actuelles.",
    content: [
      {
        subtitle: "La cybersécurité, un enjeu pour tous",
        text: "Particulier ou professionnel, vous êtes une cible potentielle. Phishing, ransomwares, vols de données... Les menaces sont réelles et en constante évolution. Je vous aide à mettre en place des protections efficaces et adaptées à votre niveau de risque, sans complexité inutile."
      },
      {
        subtitle: "Services proposés",
        list: [
          { title: "Audit de sécurité", desc: "Analyse de vos pratiques, identification des failles et recommandations concrètes." },
          { title: "Configuration 2FA & authentification", desc: "Mise en place de l'authentification à deux facteurs sur tous vos comptes critiques." },
          { title: "Gestionnaires de mots de passe", desc: "Installation et formation sur Bitwarden, 1Password ou KeePass." },
          { title: "Développement d'outils de sécurité", desc: "Scripts et outils sur mesure pour automatiser vos contrôles de sécurité." }
        ]
      },
      {
        subtitle: "Accompagnement complet",
        simpleList: [
          "Formation et sensibilisation aux bonnes pratiques",
          "Sécurisation des postes de travail et mobiles",
          "Configuration VPN et navigation sécurisée",
          "Sauvegarde chiffrée de vos données sensibles",
          "Veille sur les fuites de données (Have I Been Pwned)"
        ]
      }
    ],
    techs: ["2FA/MFA", "Bitwarden", "VPN", "Chiffrement", "Linux", "Audit sécurité"]
  },
  {
    id: "performance",
    title: "Performance & Stack technique optimisée",
    icon: Zap,
    accroche: "Je recherche constamment le meilleur ratio performance/qualité. Technologies minimalistes, temps de chargement instantanés, coûts réduits. Chaque ligne de code est pensée pour l'efficacité.",
    content: [
      {
        subtitle: "Ma philosophie : moins c'est plus",
        text: "Dans un monde où les sites web deviennent de plus en plus lourds, je prends le contre-pied. J'utilise des technologies qui génèrent uniquement ce qui est nécessaire : pas de JavaScript superflu, pas de dépendances inutiles. Résultat : des sites ultra-rapides qui se chargent instantanément, même en connexion mobile, et des coûts d'hébergement divisés par 10."
      },
      {
        subtitle: "Technologies que je maîtrise",
        text: "Astro pour des sites statiques ultra-performants (score Lighthouse proche de 100). Svelte pour des interfaces réactives sans virtual DOM. C et PHP pour certains outils métier, scripts spécialisés et logiques applicatives robustes. TypeScript pour un code front-end maintenable."
      },
      {
        subtitle: "Avantages concrets pour vous",
        simpleList: [
          "Score Google PageSpeed > 95/100",
          "Temps de chargement < 1 seconde",
          "Meilleurs Core Web Vitals (Lighthouse)",
          "Coûts d'hébergement minimaux",
          "Sites accessibles partout, même en 3G",
          "Maintenance simplifiée, moins de bugs"
        ]
      }
    ],
    techs: ["Astro", "Svelte", "C et PHP", "TypeScript"]
  },
  {
    id: "platform",
    title: "Platform Engineering léger",
    icon: Server,
    accroche: "Hébergement, déploiement et infrastructure modernes sans la complexité et les coûts du cloud. Des solutions simples et robustes pour vos applications web.",
    content: [
      {
        subtitle: "Pas de cloud surdimensionné, juste ce qu'il vous faut",
        text: "Les géants du cloud (AWS, Azure) sont souvent trop complexes et coûteux pour les PME. Je configure des infrastructures simples et performantes sur VPS. Vous obtenez puissance et contrôle sans les factures explosives."
      },
      {
        subtitle: "Ce que je fais pour vous",
        list: [
          { title: "Configuration serveurs Linux", desc: "VPS Debian/Ubuntu sécurisés et optimisés." },
          { title: "Déploiement avec Docker & Kamal", desc: "Environnements isolés et déploiements zero-downtime." },
          { title: "Infrastructure complète", desc: "Reverse proxy (Nginx), Base de données, CI/CD GitHub Actions." },
          { title: "Monitoring & Sécurité", desc: "Surveillance serveurs, logs, SSL automatique, Firewall." }
        ]
      },
      {
        subtitle: "Avantages VPS vs Cloud",
        simpleList: [
          "Coûts prévisibles et très faibles",
          "Performances excellentes (serveurs dédiés)",
          "Contrôle total (accès root)",
          "Sécurité renforcée et sauvegardes auto"
        ]
      }
    ],
    techs: ["Linux", "Docker", "Kamal", "Nginx", "GitHub Actions", "OVH", "Let's Encrypt"]
  }
];
---

<BaseLayout title={title} description={description}>
  <Header />

  <main class="pt-24 pb-20">
    <!-- Page Header -->
    <section class="container-custom mb-20 md:mb-32 text-center">
      <h1 class="text-4xl md:text-6xl font-bold mb-6 mt-[150px] text-main reveal">
        Services de développement web <br />
        <span class="text-highlight">& solutions digitales</span>
      </h1>
      <p class="text-xl text-secondary max-w-3xl mx-auto leading-relaxed reveal delay-100 mb-[150px]">
        Des solutions sur mesure pour développer votre activité en ligne, automatiser vos processus et créer des outils qui vous font gagner du temps et de l'argent. Sans complexité inutile, avec des technologies modernes et éprouvées.
      </p>
    </section>

    <!-- Services Content -->
    <div class="flex flex-col gap-64 pb-32">
      {services.map((service, index) => (
        <section id={service.id} class="container-custom scroll-mt-32 ">
          <div class="grid lg:grid-cols-12 gap-10 lg:gap-24 items-start">
            <!-- Sticky Title/Icon Column -->
            <div class={`lg:col-span-5 lg:sticky lg:top-32 h-fit ${index % 2 === 1 ? 'lg:order-last' : ''}`}>
              <div class="glass-card p-6 md:p-8 relative overflow-hidden group border border-white/5 shadow-xl shadow-black/20">
                <div class="absolute top-0 right-0 -mr-12 -mt-12 p-24 bg-primary-500/10 rounded-full blur-3xl group-hover:bg-primary-500/20 transition-all duration-700"></div>
                
                <div class="w-16 h-16 rounded-2xl bg-primary-600/10 flex items-center justify-center mb-6 text-primary-400 group-hover:scale-110 transition-transform duration-500 border border-primary-500/20">
                  <service.icon class="w-8 h-8" />
                </div>
                
                <h2 class="text-2xl md:text-3xl font-bold mb-4 leading-tight text-main">{service.title}</h2>
                <p class="text-secondary text-base md:text-lg mb-6 leading-relaxed font-light">
                  {service.accroche}
                </p>

                <div class="flex flex-wrap gap-2">
                  {service.techs.map(tech => (
                    <span class="px-3 py-1 rounded-full text-xs font-medium bg-dark-800/80 text-secondary border border-dark-600/50 transition-colors">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </div>

            <!-- Content Column -->
            <div class="lg:col-span-7 space-y-16 lg:py-4">
              {service.content.map((block) => (
                <div class="reveal">
                  <h3 class="text-2xl md:text-3xl font-bold mb-6 flex items-center gap-4 text-main">
                    <span class="w-12 h-1.5 bg-primary-500 rounded-full shadow-[0_0_10px_rgba(59,130,246,0.5)]"></span>
                    {block.subtitle}
                  </h3>
                  
                  {block.text && (
                    <p class="text-secondary text-lg md:text-xl leading-8 mb-8 font-light">
                      {block.text}
                    </p>
                  )}

                  {block.list && (
                    <div class="grid md:grid-cols-2 gap-6 mt-8">
                      {block.list.map((item) => (
                        <div class="surface-elevated p-8 rounded-2xl border border-dark-700/50 transition-all duration-300">
                          <h4 class="text-lg font-bold text-main mb-3">{item.title}</h4>
                          <p class="text-secondary text-sm leading-relaxed">{item.desc}</p>
                        </div>
                      ))}
                    </div>
                  )}

                  {block.simpleList && (
                    <ul class="grid sm:grid-cols-2 gap-x-8 gap-y-4 mt-6">
                      {block.simpleList.map((item) => (
                        <li class="flex items-start gap-3 text-secondary text-lg">
                          <CheckCircle2 class="w-6 h-6 text-primary-400 shrink-0 mt-0.5" />
                          <span class="font-light">{item}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              ))}
            </div>
          </div>
        </section>
      ))}
    </div>

    <!-- CTA Section (Footer part of the content) -->
    <section class="container-custom mt-32">
      <div class="glass-card p-12 md:p-16 text-center relative overflow-hidden">
        <div class="absolute inset-0 bg-primary-600/5"></div>
        <div class="absolute -top-24 -right-24 w-96 h-96 bg-primary-500/20 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-primary-500/20 rounded-full blur-3xl"></div>
        
        <div class="relative z-10 max-w-2xl mx-auto">
          <h2 class="text-3xl md:text-4xl font-bold mb-6">Prêt à démarrer votre projet ?</h2>
          <p class="text-xl text-secondary mb-10">
            Discutons de vos besoins et trouvons ensemble la solution la plus adaptée à votre activité.
          </p>
          
          <div class="flex flex-col md:flex-row items-center justify-center gap-6">
            <a href="/contact" class="btn-primary text-lg px-8 py-4 shadow-lg shadow-primary-500/25">
              Demander un devis
              <ArrowRight class="w-5 h-5" />
            </a>
          </div>

          <div class="mt-12 pt-8 border-t border-dark-700/50 flex flex-col md:flex-row items-center justify-center gap-4 text-sm text-secondary">
            <span class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-green-500"></div>
              Perpignan & périphérie
            </span>
            <span class="hidden md:block">•</span>
            <span class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-blue-500"></div>
              À distance partout en France
            </span>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

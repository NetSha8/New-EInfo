---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = "Informatique Pyrénées-Orientales (66) | Services pour TPE/PME";
const description = "Prestataire informatique pour TPE/PME dans les Pyrénées-Orientales: dépannage, création de site web, sécurité et hébergement VPS.";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Services informatiques Pyrénées-Orientales",
  serviceType: "Prestataire informatique TPE/PME",
  areaServed: ["Pyrénées-Orientales", "Rivesaltes", "Perpignan", "France"],
  provider: { "@id": "https://einformatique.fr/#business" },
  url: "https://einformatique.fr/informatique-pyrenees-orientales"
};
---

<BaseLayout title={title} description={description} jsonLd={serviceSchema}>
  <Header />
  <main class="pt-28 pb-20">
    <section class="container-custom max-w-4xl space-y-8">
      <h1 class="text-4xl md:text-5xl font-bold text-main">Prestataire informatique dans les Pyrénées-Orientales</h1>
      <p class="text-lg text-secondary">Vous cherchez un partenaire local pour maintenir votre informatique sans complexité inutile ? J'accompagne les TPE/PME du 66 sur l'exploitation quotidienne et les évolutions techniques.</p>
      <p class="text-secondary">Base à Rivesaltes, interventions régulières sur Perpignan, Canet, Saint-Cyprien et Cabestany, avec support à distance dans toute la France.</p>
    </section>

    <section class="container-custom max-w-4xl mt-12">
      <h2 class="text-2xl font-bold text-main mb-4">Services disponibles</h2>
      <div class="flex flex-wrap gap-3 text-sm">
        <a class="btn-secondary" href="/services#depannage">dépannage informatique Pyrénées-Orientales</a>
        <a class="btn-secondary" href="/services#sites-web">création de site web</a>
        <a class="btn-secondary" href="/services#cybersecurite">sécurité informatique PME</a>
        <a class="btn-secondary" href="/services#hebergement">hébergement VPS</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
